{%- style -%}
  #section-{{ section.id }} .hero-banner {
    min-height: {{ section.settings.height }}vh;
  }
  #section-{{ section.id }} .hero-banner__overlay {
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

<div id="section-{{ section.id }}">
  <div class="hero-banner">
    {%- if section.settings.image != blank -%}
      <img
        class="hero-banner__image"
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="
          {{ section.settings.image | image_url: width: 800 }} 800w,
          {{ section.settings.image | image_url: width: 1200 }} 1200w,
          {{ section.settings.image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="{{ 1920 | divided_by: section.settings.image.aspect_ratio | round }}"
      >
    {%- else -%}
      <div class="hero-banner__placeholder">
        {{ 'collection-1' | placeholder_svg_tag: 'hero-banner__placeholder-svg' }}
      </div>
    {%- endif -%}

    <div class="hero-banner__overlay"></div>

    <div class="hero-banner__content hero-banner__content--{{ section.settings.text_align }}">
      <div class="container">
        {%- if section.settings.tag != blank -%}
          <span class="hero-banner__tag">{{ section.settings.tag }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}

        <div class="hero-banner__actions">
          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link }}" class="btn btn--primary btn--large">
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}

          {%- if section.settings.button_2_label != blank -%}
            <a href="{{ section.settings.button_2_link }}" class="btn btn--outline btn--large">
              {{ section.settings.button_2_label }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>

    {%- if section.settings.show_scroll_indicator -%}
      <div class="hero-banner__scroll-indicator" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="7 13 12 18 17 13"/><polyline points="7 6 12 11 17 6"/></svg>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Recommended: 1920x900px or larger"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Section height",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 80,
      "unit": "vh"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag line",
      "default": "🔥 NEW DROP"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Rip. Collect. Dominate."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium sealed TCG products. Booster boxes, ETBs, and packs from all your favorite games."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Secondary button label",
      "default": "View Latest Drops"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary button link"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
