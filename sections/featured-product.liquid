{%- assign product = section.settings.product -%}

<div class="section-spacing">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header section-header--{{ section.settings.text_align }}">
        {%- if section.settings.tag != blank -%}
          <span class="section-tag">{{ section.settings.tag }}</span>
        {%- endif -%}
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    {%- if product != blank -%}
      <div class="featured-product">
        <div class="featured-product__gallery">
          <div class="featured-product__main-image" data-product-gallery>
            {%- for image in product.images -%}
              <div class="featured-product__image-slide{% if forloop.first %} is-active{% endif %}" data-image-slide="{{ forloop.index0 }}">
                <img
                  src="{{ image | image_url: width: 800 }}"
                  srcset="
                    {{ image | image_url: width: 400 }} 400w,
                    {{ image | image_url: width: 600 }} 600w,
                    {{ image | image_url: width: 800 }} 800w
                  "
                  alt="{{ image.alt | default: product.title }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | divided_by: image.aspect_ratio | round }}"
                  class="featured-product__img"
                >
              </div>
            {%- endfor -%}
          </div>
          {%- if product.images.size > 1 -%}
            <div class="featured-product__thumbs">
              {%- for image in product.images -%}
                <button
                  class="featured-product__thumb{% if forloop.first %} is-active{% endif %}"
                  data-thumb-index="{{ forloop.index0 }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  <img
                    src="{{ image | image_url: width: 100 }}"
                    alt=""
                    width="80"
                    height="80"
                    loading="lazy"
                  >
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        <div class="featured-product__info">
          {%- if product.vendor != blank -%}
            <span class="featured-product__vendor">{{ product.vendor }}</span>
          {%- endif -%}

          <h2 class="featured-product__title">
            <a href="{{ product.url }}">{{ product.title }}</a>
          </h2>

          <div class="featured-product__price">
            {%- if product.compare_at_price > product.price -%}
              <span class="featured-product__price-sale">{{ product.price | money }}</span>
              <span class="featured-product__price-compare">{{ product.compare_at_price | money }}</span>
              <span class="featured-product__price-badge">
                Save {{ product.compare_at_price | minus: product.price | money }}
              </span>
            {%- else -%}
              <span class="featured-product__price-regular">{{ product.price | money }}</span>
            {%- endif -%}
          </div>

          {%- if product.description != blank -%}
            <div class="featured-product__description rte">
              {{ product.description | truncatewords: 40 }}
            </div>
          {%- endif -%}

          {%- if product.available -%}
            <form method="post" action="/cart/add" data-add-to-cart-form>
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">

              {%- if product.variants.size > 1 -%}
                <div class="featured-product__variants">
                  <label for="featured-variant-{{ section.id }}" class="featured-product__variant-label">Option</label>
                  <select name="id" id="featured-variant-{{ section.id }}" class="featured-product__variant-select">
                    {%- for variant in product.variants -%}
                      <option
                        value="{{ variant.id }}"
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ variant.title }}{% unless variant.available %} — Sold Out{% endunless %} — {{ variant.price | money }}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              {%- endif -%}

              <div class="featured-product__actions">
                <div class="featured-product__quantity">
                  <button type="button" class="qty-btn" data-qty-minus aria-label="Decrease quantity">−</button>
                  <input type="number" name="quantity" value="1" min="1" class="qty-input" data-qty-input aria-label="Quantity">
                  <button type="button" class="qty-btn" data-qty-plus aria-label="Increase quantity">+</button>
                </div>
                <button type="submit" class="btn btn--primary btn--large featured-product__add-btn" data-add-to-cart>
                  <span data-add-to-cart-text>Add to Cart</span>
                  <span class="btn__spinner" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="30 60" /></svg>
                  </span>
                </button>
              </div>
            </form>
          {%- else -%}
            <button class="btn btn--outline btn--large" disabled>Sold Out</button>
          {%- endif -%}

          {%- if section.settings.show_trust_badges -%}
            <div class="featured-product__trust">
              <div class="trust-badge">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>Authentic Guaranteed</span>
              </div>
              <div class="trust-badge">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>Fast Shipping</span>
              </div>
              <div class="trust-badge">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Factory Sealed</span>
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- else -%}
      <div class="featured-product featured-product--placeholder">
        <div class="featured-product__gallery">
          <div class="featured-product__main-image">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-img' }}
          </div>
        </div>
        <div class="featured-product__info">
          <span class="featured-product__vendor">Vendor</span>
          <h2 class="featured-product__title">Featured Product Title</h2>
          <div class="featured-product__price">
            <span class="featured-product__price-regular">$49.99</span>
          </div>
          <p class="featured-product__description">Select a product in the theme editor to feature here.</p>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured product",
  "tag": "section",
  "class": "featured-product-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag line",
      "default": "⚡ HERO PRODUCT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "This Week's Featured Drop"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Header alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured product"
    }
  ]
}
{% endschema %}
