<div class="section-spacing">
  <div class="container">
    <div class="page-404">
      <span class="page-404__code">404</span>
      <h1 class="page-404__title">Page Not Found</h1>
      <p class="page-404__text">Looks like this page pulled a rare miss. The page you're looking for doesn't exist or has been moved.</p>
      <div class="page-404__actions">
        <a href="/" class="btn btn--primary btn--large">Back to Home</a>
        <a href="/collections/all" class="btn btn--outline btn--large">Browse Products</a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "404 page",
  "tag": "section",
  "class": "page-404-section",
  "settings": []
}
{% endschema %}
