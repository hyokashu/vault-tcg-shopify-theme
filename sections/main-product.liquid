<style>
/* ---------- PRODUCT PAGE (premium white) ---------- */

/* White canvas override  scopes all product page tokens */
.product-layout{
  --pp-white:#ffffff;
  --pp-raised:#f9fafb;
  --pp-border:#e5e7eb;
  --pp-text:#111827;
  --pp-muted:#6b7280;
  --pp-accent:#7C3AED;
  --pp-gold:#f59e0b;
  --pp-success:#059669;
  --pp-danger:#dc2626;
  --pp-warn:#d97706;
  background:#ffffff;
  padding-bottom:80px;
}

/* Breadcrumbs */
.breadcrumbs{display:flex;align-items:center;gap:8px;font-size:.78rem;color:var(--pp-muted);margin-bottom:28px;flex-wrap:wrap}
.breadcrumbs a{color:var(--pp-muted);transition:color 0.2s ease}
.breadcrumbs a:hover{color:var(--pp-accent)}

/* Two-column grid */
.product-page{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start}

/*  GALLERY  */
.product-page__gallery{position:sticky;top:88px}
.product-page__gallery-wrap{position:relative}
.product-page__gallery-badges{position:absolute;top:12px;left:12px;z-index:2;display:flex;flex-direction:column;gap:6px;pointer-events:none}

/* Gallery badge chips */
.pp-badge{display:inline-flex;align-items:center;gap:4px;font-size:.68rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:4px 10px;border-radius:6px;line-height:1}
.pp-badge--sale{background:var(--pp-danger);color:#fff}
.pp-badge--new{background:#111827;color:#fff}
.pp-badge--low{background:rgba(217,119,6,.12);color:var(--pp-warn);border:1px solid rgba(217,119,6,.25)}

/* Main image container */
.product-page__main-image{border-radius:12px;overflow:hidden;background:var(--pp-raised);position:relative;border:1px solid var(--pp-border);min-height:300px}
.product-page__main-image .placeholder-pack{width:100%;height:auto;display:block;aspect-ratio:240/340}
.product-page__image-slide{display:none}
.product-page__image-slide.is-active{display:block}
.product-page__img{width:100%;display:block;transition:transform .5s cubic-bezier(.25,.46,.45,.94)}
.product-page__main-image:hover .product-page__img{transform:scale(1.04)}

/* Gallery nav arrows */
.pp-gallery-arrow{position:absolute;top:50%;transform:translateY(-50%);width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,.92);border:1px solid var(--pp-border);color:var(--pp-text);display:flex;align-items:center;justify-content:center;cursor:pointer;opacity:0;transition:opacity .2s;box-shadow:0 2px 8px rgba(0,0,0,.08);backdrop-filter:blur(4px)}
.product-page__main-image:hover .pp-gallery-arrow{opacity:1}
.pp-gallery-arrow--prev{left:12px}
.pp-gallery-arrow--next{right:12px}
.pp-gallery-arrow:hover{background:#fff;box-shadow:0 4px 16px rgba(0,0,0,.12)}

/* Image counter pill */
.pp-gallery-counter{position:absolute;bottom:12px;left:50%;transform:translateX(-50%);background:rgba(255,255,255,.88);backdrop-filter:blur(4px);border:1px solid var(--pp-border);border-radius:20px;padding:3px 12px;font-size:.72rem;color:var(--pp-muted);pointer-events:none}

/* Thumbnail strip */
.product-page__thumbs{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap}
.product-page__thumb{width:76px;height:76px;border-radius:8px;overflow:hidden;border:2px solid transparent;background:var(--pp-raised);cursor:pointer;transition:border-color 0.2s ease;padding:0;flex-shrink:0}
.product-page__thumb.is-active,.product-page__thumb:hover{border-color:var(--pp-accent)}
.product-page__thumb img{width:100%;height:100%;object-fit:cover}

/*  PRODUCT INFO  */
.product-page__info{display:flex;flex-direction:column;gap:0}

/* Status badges row */
.pp-status-badges{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}
.pp-status-badge{display:inline-flex;align-items:center;gap:5px;font-size:.7rem;font-weight:600;padding:4px 10px;border-radius:6px;line-height:1}
.pp-status-badge--sealed{background:rgba(124,58,237,.08);color:var(--pp-accent);border:1px solid rgba(124,58,237,.2)}
.pp-status-badge--auth{background:rgba(5,150,105,.08);color:var(--pp-success);border:1px solid rgba(5,150,105,.2)}
.pp-status-badge--low{background:rgba(220,38,38,.08);color:var(--pp-danger);border:1px solid rgba(220,38,38,.2)}

/* Title */
.pp-title{font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;font-size:clamp(1.4rem,2.5vw,2rem);line-height:1.15;color:var(--pp-text);margin-bottom:8px;letter-spacing:-.02em;font-weight:700}

/* Vendor / type */
.pp-meta-row{display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap}
.pp-meta-link{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:3px 10px;border-radius:20px;background:rgba(124,58,237,.08);color:var(--pp-accent);border:1px solid rgba(124,58,237,.2);transition:all 0.2s ease}
.pp-meta-link:hover{background:var(--pp-accent);color:#fff}
.pp-meta-tag{font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;padding:3px 10px;border-radius:20px;background:var(--pp-raised);color:var(--pp-muted);border:1px solid var(--pp-border)}

/* Rating row */
.pp-rating-row{display:flex;align-items:center;gap:8px;margin-bottom:14px;flex-wrap:wrap}
.pp-stars{display:flex;gap:2px;color:var(--pp-gold)}
.pp-stars--sm{gap:1px}
.pp-rating-link{font-size:.82rem;color:var(--pp-accent);text-decoration:underline;text-underline-offset:2px}
.pp-rating-sep{color:var(--pp-border);font-size:.9rem}
.pp-viewing{display:inline-flex;align-items:center;gap:5px;font-size:.78rem;color:var(--pp-muted)}
.pp-viewing-dot{width:7px;height:7px;border-radius:50%;background:var(--pp-success);animation:pulse 2s infinite;flex-shrink:0}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.4)}}

/* Section divider */
.pp-divider{height:1px;background:var(--pp-border);margin:14px 0}
.pp-section-divider{height:1px;background:var(--pp-border);margin:48px 0}

/* Price block */
.pp-price-block{background:var(--pp-raised);border:1px solid var(--pp-border);border-radius:12px;padding:16px 18px;margin-bottom:4px}
.pp-price-row{display:flex;align-items:baseline;gap:10px;flex-wrap:wrap;margin-bottom:6px}
.pp-price{font-size:2.2rem;font-weight:800;line-height:1;color:var(--pp-text);letter-spacing:-.03em;font-variant-numeric:tabular-nums}
.pp-price--sale{color:var(--pp-danger)}
.pp-price-compare{font-size:1.1rem;color:var(--pp-muted);text-decoration:line-through;font-weight:400}
.pp-price-save{font-size:.75rem;font-weight:700;padding:3px 10px;border-radius:20px;background:rgba(5,150,105,.1);color:var(--pp-success);border:1px solid rgba(5,150,105,.2)}
.pp-afterpay{font-size:.82rem;color:var(--pp-muted);margin-bottom:6px}
.pp-afterpay strong{color:var(--pp-text)}
.pp-price-note{font-size:.72rem;color:var(--pp-muted)}
.pp-price-note a{color:var(--pp-accent)}

/* Product detail grid */
.pp-detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:4px}
.pp-detail-item{display:flex;flex-direction:column;gap:2px;background:var(--pp-raised);border:1px solid var(--pp-border);border-radius:8px;padding:10px 12px}
.pp-detail-label{font-size:.68rem;text-transform:uppercase;letter-spacing:.06em;color:var(--pp-muted);font-weight:500}
.pp-detail-value{font-size:.88rem;font-weight:600;color:var(--pp-text)}

/* Stock / urgency */
.pp-urgency-row{display:flex;flex-direction:column;gap:7px;margin-bottom:14px}
.pp-stock{display:inline-flex;align-items:center;gap:6px;font-size:.82rem;font-weight:600}
.pp-stock--in{color:var(--pp-success)}
.pp-stock--low{color:var(--pp-warn)}
.pp-stock--out{color:var(--pp-danger)}
.pp-stock-bar-wrap{display:flex;align-items:center;gap:10px}
.pp-stock-bar{flex:1;height:4px;background:var(--pp-border);border-radius:4px;overflow:hidden;max-width:120px}
.pp-stock-bar-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--pp-danger),var(--pp-warn));transition:width .5s ease}
.pp-stock-bar-label{font-size:.7rem;color:var(--pp-warn);font-weight:600}

/* Variant swatches */
.pp-variants{margin-bottom:14px}
.pp-option{margin-bottom:12px}
.pp-option-label{display:block;font-size:.78rem;font-weight:600;margin-bottom:7px;color:var(--pp-text);text-transform:uppercase;letter-spacing:.05em}
.pp-option-values{display:flex;flex-wrap:wrap;gap:7px}
.pp-swatch{display:inline-flex;align-items:center;padding:7px 16px;border-radius:8px;border:1.5px solid var(--pp-border);font-size:.85rem;cursor:pointer;transition:all 0.2s ease;background:var(--pp-white);color:var(--pp-text);user-select:none}
.pp-swatch:hover{border-color:var(--pp-accent);color:var(--pp-accent)}
.pp-swatch.is-selected{border-color:var(--pp-accent);background:rgba(124,58,237,.06);color:var(--pp-accent);font-weight:700}

/* Buy box */
.pp-buy-box{display:flex;gap:8px;align-items:stretch;margin-bottom:10px}
.pp-qty{display:flex;align-items:center;background:var(--pp-white);border:1.5px solid var(--pp-border);border-radius:10px;overflow:hidden;flex-shrink:0}
.pp-qty-btn{padding:0 14px;height:48px;font-size:1.2rem;color:var(--pp-muted);background:none;border:none;cursor:pointer;transition:color 0.2s ease}
.pp-qty-btn:hover{color:var(--pp-text)}
.pp-qty-input{width:42px;text-align:center;font-size:.9rem;font-weight:600;color:var(--pp-text);border:none;background:none;padding:0}
.pp-atc-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:8px;font-size:.92rem;height:48px;border-radius:10px !important}
.pp-wishlist-btn{width:48px;height:48px;border-radius:10px;border:1.5px solid var(--pp-border);background:var(--pp-white);color:var(--pp-muted);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;transition:all 0.2s ease}
.pp-wishlist-btn:hover,.pp-wishlist-btn.is-active{border-color:var(--pp-danger);color:var(--pp-danger)}
.pp-wishlist-btn.is-active svg{fill:var(--pp-danger)}

/* Dynamic checkout */
.pp-dynamic-checkout{margin-bottom:14px}
.pp-dynamic-checkout .shopify-payment-button__button{border-radius:10px !important;font-size:.9rem !important}

/* Notify */
.pp-notify{margin-bottom:14px;padding:14px;background:var(--pp-raised);border:1px solid var(--pp-border);border-radius:10px;text-align:center}
.pp-notify p{color:var(--pp-muted);margin-bottom:8px;font-size:.85rem}

/* Trust row  individual bordered cards */
.pp-trust-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:14px 0}
.pp-trust-card{display:flex;align-items:flex-start;gap:10px;background:var(--pp-white);border:1px solid var(--pp-border);border-radius:10px;padding:12px;transition:box-shadow 0.2s ease}
.pp-trust-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.06)}
.pp-trust-card svg{flex-shrink:0;margin-top:1px}
.pp-trust-title{font-size:.8rem;font-weight:600;color:var(--pp-text);margin-bottom:1px}
.pp-trust-sub{font-size:.7rem;color:var(--pp-muted)}

/* Payment icons */
.pp-payment-row{display:flex;align-items:center;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.pp-payment-label{font-size:.7rem;color:var(--pp-muted);white-space:nowrap}
.pp-payment-icons{display:flex;align-items:center;gap:5px;flex-wrap:wrap}
.payment-icon{height:22px;width:auto;border-radius:4px;filter:grayscale(20%);opacity:.75}

/* Accordions */
.pp-accordions{border-top:1px solid var(--pp-border);margin-bottom:16px}
.pp-accordion{border-bottom:1px solid var(--pp-border)}
.pp-accordion__title{display:flex;align-items:center;justify-content:space-between;padding:14px 0;cursor:pointer;font-weight:600;font-size:.9rem;color:var(--pp-text);list-style:none;gap:16px;user-select:none}
.pp-accordion__title::-webkit-details-marker{display:none}
.pp-accordion__title span{flex:1}
.pp-accordion__icon{flex-shrink:0;transition:transform .25s;color:var(--pp-muted)}
.pp-accordion[open] .pp-accordion__icon{transform:rotate(180deg)}
.pp-accordion__body{padding:0 0 16px;color:var(--pp-muted);line-height:1.75;font-size:.88rem}
.pp-accordion__body ul{padding-left:20px;margin:8px 0}
.pp-accordion__body li{margin-bottom:4px}
.pp-accordion__body a{color:var(--pp-accent)}

/* Share */
.pp-share{display:flex;align-items:center;gap:8px;font-size:.78rem;color:var(--pp-muted)}
.pp-share-btn{display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:50%;background:var(--pp-raised);border:1px solid var(--pp-border);color:var(--pp-muted);transition:all 0.2s ease}
.pp-share-btn:hover{background:var(--pp-accent);border-color:var(--pp-accent);color:#fff}

/*  PRODUCT TABS  */
.pp-tabs__nav{display:flex;gap:0;border-bottom:2px solid var(--pp-border);margin-bottom:24px;overflow-x:auto}
.pp-tab-btn{padding:12px 20px;font-size:.88rem;font-weight:600;color:var(--pp-muted);background:none;border:none;border-bottom:2px solid transparent;margin-bottom:-2px;cursor:pointer;transition:all 0.2s ease;white-space:nowrap}
.pp-tab-btn:hover{color:var(--pp-text)}
.pp-tab-btn.is-active{color:var(--pp-accent);border-bottom-color:var(--pp-accent)}
.pp-tab-panel{display:none}
.pp-tab-panel.is-active{display:block}
.pp-tab-card{background:var(--pp-white);border:1px solid var(--pp-border);border-radius:12px;padding:24px}
.pp-tab-card.rte{color:var(--pp-muted);line-height:1.8;font-size:.92rem}
.pp-tab-card.rte h3,.pp-tab-card.rte h4{color:var(--pp-text);margin:16px 0 8px}
.pp-tab-card.rte ul{padding-left:20px}
.pp-tab-card.rte li{margin-bottom:4px}
.pp-tab-heading{font-size:1rem;font-weight:700;color:var(--pp-text);margin-bottom:16px}

/* Box contents tab */
.pp-box-list{display:flex;flex-direction:column;gap:8px;margin-bottom:20px}
.pp-box-item{display:flex;align-items:flex-start;gap:12px;background:var(--pp-raised);border:1px solid var(--pp-border);border-radius:8px;padding:12px 14px}
.pp-box-item__icon{width:26px;height:26px;border-radius:50%;background:rgba(124,58,237,.1);color:var(--pp-accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.pp-box-item__header{display:flex;align-items:baseline;justify-content:space-between;gap:12px;margin-bottom:2px}
.pp-box-item__label{font-size:.88rem;font-weight:600;color:var(--pp-text)}
.pp-box-item__value{font-size:.88rem;font-weight:700;color:var(--pp-accent);font-variant-numeric:tabular-nums}
.pp-box-item__desc{font-size:.78rem;color:var(--pp-muted)}

/* Pull rates */
.pp-pull-rates{background:var(--pp-raised);border:1px solid var(--pp-border);border-radius:8px;padding:16px}
.pp-pull-rates__heading{font-size:.88rem;font-weight:700;color:var(--pp-text);margin-bottom:6px}
.pp-pull-rates__note{font-size:.8rem;color:var(--pp-muted);margin-bottom:12px;line-height:1.6}
.pp-pull-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.pp-pull-item{display:flex;justify-content:space-between;align-items:center;background:var(--pp-white);border:1px solid var(--pp-border);border-radius:6px;padding:8px 10px}
.pp-pull-item__label{font-size:.76rem;color:var(--pp-muted)}
.pp-pull-item__value{font-size:.76rem;font-weight:700;color:var(--pp-text)}

/* Reviews tab */
.pp-review-summary{display:flex;align-items:center;gap:28px;padding-bottom:20px;margin-bottom:20px;border-bottom:1px solid var(--pp-border)}
.pp-review-score{display:flex;flex-direction:column;align-items:center;gap:6px}
.pp-review-score__num{font-size:3rem;font-weight:800;color:var(--pp-text);line-height:1;letter-spacing:-.04em}
.pp-review-score__count{font-size:.75rem;color:var(--pp-muted)}
.pp-rating-bars{flex:1;display:flex;flex-direction:column;gap:6px}
.pp-rating-bar-row{display:flex;align-items:center;gap:6px}
.pp-rating-bar-label{font-size:.75rem;color:var(--pp-muted);width:10px;text-align:right}
.pp-rating-bar-track{flex:1;height:6px;background:var(--pp-raised);border-radius:4px;overflow:hidden;border:1px solid var(--pp-border)}
.pp-rating-bar-fill{height:100%;background:var(--pp-gold);border-radius:4px;transition:width .4s ease}
.pp-rating-bar-pct{font-size:.72rem;color:var(--pp-muted);width:28px}
.pp-reviews-list{display:flex;flex-direction:column;gap:12px}
.pp-review{background:var(--pp-white);border:1px solid var(--pp-border);border-radius:10px;padding:16px}
.pp-review__header{margin-bottom:8px}
.pp-review__author-row{display:flex;align-items:center;gap:8px;margin-bottom:4px}
.pp-review__author{font-size:.88rem;font-weight:600;color:var(--pp-text)}
.pp-review__verified{display:inline-flex;align-items:center;gap:3px;font-size:.68rem;font-weight:600;background:rgba(5,150,105,.08);color:var(--pp-success);border:1px solid rgba(5,150,105,.2);padding:2px 7px;border-radius:4px}
.pp-review__stars-row{display:flex;align-items:center;gap:6px}
.pp-review__date{font-size:.72rem;color:var(--pp-muted)}
.pp-review__text{font-size:.88rem;color:var(--pp-muted);line-height:1.7;margin-bottom:10px}
.pp-review__helpful{display:inline-flex;align-items:center;gap:5px;font-size:.75rem;color:var(--pp-muted);cursor:pointer;transition:color 0.2s ease}
.pp-review__helpful:hover{color:var(--pp-text)}

/*  RECENT SALES  */
.pp-recent-sales{background:var(--pp-white);border:1px solid var(--pp-border);border-radius:12px;padding:20px 24px}
.pp-recent-sales__heading{display:flex;align-items:center;gap:8px;font-size:.88rem;font-weight:700;color:var(--pp-text);margin-bottom:14px}
.pp-sales-list{display:flex;flex-direction:column;gap:6px}
.pp-sale-item{display:flex;align-items:center;justify-content:space-between;background:var(--pp-raised);border:1px solid var(--pp-border);border-radius:8px;padding:10px 14px}
.pp-sale-item__info{display:flex;flex-direction:column;gap:1px}
.pp-sale-item__name{font-size:.85rem;font-weight:600;color:var(--pp-text)}
.pp-sale-item__time{font-size:.72rem;color:var(--pp-muted)}
.pp-sale-item__price{font-size:.88rem;font-weight:700;color:var(--pp-accent);font-variant-numeric:tabular-nums}

/*  RELATED PRODUCTS  */
.pp-related{margin-top:0}
.pp-related__header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.pp-related__heading{font-family:-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;font-size:clamp(1.3rem,2.5vw,1.7rem);text-transform:uppercase;color:var(--pp-text)}
.pp-related__link{font-size:.85rem;font-weight:600;color:var(--pp-accent);transition:opacity 0.2s ease}
.pp-related__link:hover{opacity:.7}

/*  STICKY ATC BAR  */
.sticky-atc{position:fixed;bottom:0;left:0;right:0;z-index:300;background:#fff;border-top:1px solid var(--pp-border);padding:10px 0;box-shadow:0 -4px 24px rgba(0,0,0,.08);opacity:0;pointer-events:none;transform:translateY(6px);transition:opacity .3s,transform .3s}
.sticky-atc.is-visible{opacity:1;pointer-events:all;transform:translateY(0)}
.sticky-atc__inner{display:flex;align-items:center;justify-content:space-between;gap:16px}
.sticky-atc__info{display:flex;align-items:center;gap:12px;min-width:0}
.sticky-atc__img{border-radius:6px;object-fit:cover;width:40px;height:40px;flex-shrink:0;border:1px solid var(--pp-border)}
.sticky-atc__title{font-size:.82rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#111827}
.sticky-atc__price{font-size:.9rem;color:var(--pp-accent);font-weight:700}
.sticky-atc__btn{flex-shrink:0;white-space:nowrap}

/*  RESPONSIVE  */
@media(max-width:768px){
  .product-page{grid-template-columns:1fr;gap:28px}
  .product-page__gallery{position:static}
  .pp-trust-row{grid-template-columns:repeat(3,1fr)}
  .pp-review-summary{gap:16px}
}
@media(max-width:640px){
  .pp-buy-box{flex-wrap:wrap}
  .pp-atc-btn{flex:1;min-width:0}
  .pp-trust-row{grid-template-columns:1fr 1fr}
  .pp-detail-grid{grid-template-columns:1fr 1fr}
  .pp-pull-grid{grid-template-columns:1fr}
  .sticky-atc__title{max-width:130px}
  .pp-review-summary{flex-direction:column;align-items:flex-start;gap:16px}
  .pp-tab-card{padding:16px}
}
</style>

{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  assign compare_price = product.compare_at_price
  assign sale_price = product.price
  assign on_sale = false
  if compare_price > sale_price
    assign on_sale = true
    assign savings_amount = compare_price | minus: sale_price
    assign savings_pct = savings_amount | times: 100 | divided_by: compare_price
  endif
  assign low_stock_threshold = section.settings.low_stock_threshold | default: 5
  assign inventory = current_variant.inventory_quantity
  assign track_inventory = current_variant.inventory_management

  assign detail_blocks = section.blocks | where: 'type', 'detail_item'
  assign box_blocks    = section.blocks | where: 'type', 'box_item'
  assign review_blocks = section.blocks | where: 'type', 'review'
  assign sale_blocks   = section.blocks | where: 'type', 'recent_sale'
  assign accordion_blocks = section.blocks | where: 'type', 'accordion'
-%}

{%- comment -%} Recently viewed tracking {%- endcomment -%}
<span data-product-handle="{{ product.handle }}" style="display:none" aria-hidden="true"></span>

{%- comment -%} --- STICKY MOBILE ATC --- {%- endcomment -%}
<div class="sticky-atc" data-sticky-atc aria-hidden="true">
  <div class="sticky-atc__inner container">
    <div class="sticky-atc__info">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title }}" width="40" height="40" class="sticky-atc__img">
      {%- endif -%}
      <div>
        <p class="sticky-atc__title" data-sticky-atc-title>{{ product.title | truncate: 40 }}</p>
        <p class="sticky-atc__price" data-sticky-atc-price>{{ current_variant.price | money }}</p>
      </div>
    </div>
    <button class="btn btn--primary btn--small sticky-atc__btn" data-sticky-atc-btn>
      Add to Cart
    </button>
  </div>
</div>

<div class="product-layout section-spacing">
  <div class="container">

    {%- comment -%} --- BREADCRUMBS --- {%- endcomment -%}
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span aria-hidden="true">/</span>
      {%- endif -%}
      <span aria-current="page">{{ product.title | truncate: 50 }}</span>
    </nav>

    <div class="product-page">

      {%- comment -%} ---
          GALLERY
      --- {%- endcomment -%}
      <div class="product-page__gallery">

        <div class="product-page__gallery-wrap">
          {%- comment -%} Badges {%- endcomment -%}
          <div class="product-page__gallery-badges">
            {%- if on_sale -%}
              <span class="pp-badge pp-badge--sale">-{{ savings_pct }}%</span>
            {%- endif -%}
            {%- if product.tags contains 'new' or product.tags contains 'New' -%}
              <span class="pp-badge pp-badge--new">NEW</span>
            {%- endif -%}
            {%- if track_inventory == 'shopify' and inventory <= low_stock_threshold and inventory > 0 -%}
              <span class="pp-badge pp-badge--low">Low Stock</span>
            {%- endif -%}
          </div>

          {%- comment -%} Main image {%- endcomment -%}
          <div class="product-page__main-image" data-product-gallery>
            {%- if product.images.size > 0 -%}
              {%- for image in product.images -%}
                <div class="product-page__image-slide{% if forloop.first %} is-active{% endif %}" data-image-slide="{{ forloop.index0 }}">
                  <img
                    src="{{ image | image_url: width: 800 }}"
                    srcset="{{ image | image_url: width: 500 }} 500w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1100 }} 1100w"
                    sizes="(max-width: 768px) 100vw, 50vw"
                    alt="{{ image.alt | default: product.title }}"
                    width="800"
                    height="{{ 800 | divided_by: image.aspect_ratio | round }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    class="product-page__img"
                  >
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="product-page__image-slide is-active">
                {% render 'placeholder-pack-art', color_from: '#7C3AED', color_to: '#06B6D4', index: 1 %}
              </div>
            {%- endif -%}

            {%- if product.images.size > 1 -%}
              <button class="pp-gallery-arrow pp-gallery-arrow--prev" data-gallery-prev aria-label="Previous image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="pp-gallery-arrow pp-gallery-arrow--next" data-gallery-next aria-label="Next image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
              <div class="pp-gallery-counter" aria-hidden="true">
                <span data-image-current>1</span> / {{ product.images.size }}
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Thumbnail strip {%- endcomment -%}
          {%- if product.images.size > 1 -%}
            <div class="product-page__thumbs">
              {%- for image in product.images -%}
                <button
                  class="product-page__thumb{% if forloop.first %} is-active{% endif %}"
                  data-thumb-index="{{ forloop.index0 }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  <img src="{{ image | image_url: width: 160 }}" alt="" width="80" height="80" loading="lazy">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ---
          PRODUCT INFO
      --- {%- endcomment -%}
      <div class="product-page__info">

        {%- comment -%} Status badges {%- endcomment -%}
        <div class="pp-status-badges">
          <span class="pp-status-badge pp-status-badge--sealed">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            Sealed
          </span>
          <span class="pp-status-badge pp-status-badge--auth">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            Authentic
          </span>
          {%- if track_inventory == 'shopify' and inventory <= low_stock_threshold and inventory > 0 -%}
            <span class="pp-status-badge pp-status-badge--low">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
              Only {{ inventory }} left
            </span>
          {%- endif -%}
        </div>

        {%- comment -%} Title {%- endcomment -%}
        <h1 class="pp-title">{{ product.title }}</h1>

        {%- comment -%} Vendor / type {%- endcomment -%}
        {%- if product.vendor != blank or product.type != blank -%}
          <div class="pp-meta-row">
            {%- if product.vendor != blank -%}
              <a href="{{ product.vendor | url_for_vendor }}" class="pp-meta-link">{{ product.vendor }}</a>
            {%- endif -%}
            {%- if product.type != blank -%}
              <span class="pp-meta-tag">{{ product.type }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Star rating {%- endcomment -%}
        {%- if section.settings.show_rating -%}
          <div class="pp-rating-row">
            <div class="pp-stars" aria-label="4.9 out of 5 stars">
              {%- for i in (1..5) -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endfor -%}
            </div>
            <a href="#pp-reviews-tab" class="pp-rating-link" data-tab-jump="reviews">
              {{ section.settings.review_count | default: 42 }} reviews
            </a>
            <span class="pp-rating-sep">&middot;</span>
            {%- if section.settings.show_viewing_now -%}
              <span class="pp-viewing">
                <span class="pp-viewing-dot"></span>
                <span data-viewing-count>{{ section.settings.viewing_count | default: 8 }} viewing</span>
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="pp-divider"></div>

        {%- comment -%} Price block {%- endcomment -%}
        <div class="pp-price-block">
          <div class="pp-price-row">
            {%- if on_sale -%}
              <span class="pp-price pp-price--sale" data-sticky-atc-price>{{ sale_price | money }}</span>
              <span class="pp-price-compare">{{ compare_price | money }}</span>
              <span class="pp-price-save">Save {{ savings_amount | money }}</span>
            {%- else -%}
              <span class="pp-price" data-sticky-atc-price>{{ sale_price | money }}</span>
            {%- endif -%}
          </div>

          {%- if section.settings.show_afterpay -%}
            {%- assign installment_price = sale_price | divided_by: 4 -%}
            <p class="pp-afterpay">
              or 4 interest-free payments of <strong>{{ installment_price | money }}</strong> with <strong>Afterpay</strong>
            </p>
          {%- endif -%}

          <p class="pp-price-note">
            {%- if cart.taxes_included -%}Tax included. {%- endif -%}
            {%- if shop.shipping_policy.body != blank -%}
              <a href="{{ shop.shipping_policy.url }}">Shipping</a> calculated at checkout.
            {%- endif -%}
          </p>
        </div>

        <div class="pp-divider"></div>

        {%- comment -%} Product details grid {%- endcomment -%}
        {%- if detail_blocks.size > 0 -%}
          <div class="pp-detail-grid">
            {%- for block in detail_blocks -%}
              <div class="pp-detail-item" {{ block.shopify_attributes }}>
                <span class="pp-detail-label">{{ block.settings.label }}</span>
                <span class="pp-detail-value">{{ block.settings.value }}</span>
              </div>
            {%- endfor -%}
          </div>
          <div class="pp-divider"></div>
        {%- endif -%}

        {%- comment -%} Stock + urgency {%- endcomment -%}
        <div class="pp-urgency-row">
          {%- if product.available -%}
            {%- if track_inventory == 'shopify' and inventory <= low_stock_threshold and inventory > 0 -%}
              <div class="pp-stock pp-stock--low">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
                Only {{ inventory }} left -- order soon!
              </div>
              <div class="pp-stock-bar-wrap">
                {%- assign bar_pct = inventory | times: 100 | divided_by: low_stock_threshold -%}
                <div class="pp-stock-bar"><div class="pp-stock-bar-fill" style="width:{{ bar_pct }}%"></div></div>
                <span class="pp-stock-bar-label">Selling fast</span>
              </div>
            {%- else -%}
              <div class="pp-stock pp-stock--in">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                In Stock &amp; Ready to Ship
              </div>
            {%- endif -%}
          {%- else -%}
            <div class="pp-stock pp-stock--out">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
              Sold Out
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Variant selectors + form {%- endcomment -%}
        {%- form 'product', product, data-product-form: '', data-product-id: product.id -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {%- unless product.has_only_default_variant -%}
            <div class="pp-variants">
              {%- for option in product.options_with_values -%}
                <div class="pp-option">
                  <label class="pp-option-label">
                    {{ option.name }}: <strong>{{ option.selected_value }}</strong>
                  </label>
                  <div class="pp-option-values">
                    {%- for value in option.values -%}
                      <label class="pp-swatch{% if option.selected_value == value %} is-selected{% endif %}">
                        <input
                          type="radio"
                          name="option{{ forloop.index0 }}"
                          value="{{ value | escape }}"
                          class="visually-hidden"
                          data-option-index="{{ forloop.index0 }}"
                          {% if option.selected_value == value %}checked{% endif %}
                        >
                        {{ value }}
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
              <select name="id" class="visually-hidden" data-variant-select>
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {% if variant == current_variant %}selected{% endif %}
                    {% unless variant.available %}disabled{% endunless %}
                    data-price="{{ variant.price }}"
                    data-compare-price="{{ variant.compare_at_price }}"
                  >{{ variant.title }} -- {{ variant.price | money }}</option>
                {%- endfor -%}
              </select>
            </div>
          {%- endunless -%}

          {%- comment -%} Buy box {%- endcomment -%}
          {%- if product.available -%}
            <div class="pp-buy-box">
              <div class="pp-qty">
                <button type="button" class="pp-qty-btn" data-qty-minus aria-label="Decrease quantity">&minus;</button>
                <input type="number" name="quantity" value="1" min="1" max="99" class="pp-qty-input" data-qty-input aria-label="Quantity">
                <button type="button" class="pp-qty-btn" data-qty-plus aria-label="Increase quantity">+</button>
              </div>
              <button type="submit" class="btn btn--primary btn--large pp-atc-btn" data-add-to-cart>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span data-add-to-cart-text>Add to Cart</span>
              </button>
              <button type="button" class="pp-wishlist-btn" data-wishlist-btn aria-label="Save to wishlist">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-wishlist-icon><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </button>
            </div>

            {%- if section.settings.show_dynamic_checkout -%}
              <div class="pp-dynamic-checkout">
                {{ form | payment_button }}
              </div>
            {%- endif -%}
          {%- else -%}
            <div class="pp-buy-box">
              <button class="btn btn--outline btn--large" disabled style="flex:1;opacity:.5">Sold Out</button>
            </div>
            {%- if section.settings.show_notify -%}
              <div class="pp-notify">
                <p>Want to know when this is back?</p>
                <button class="btn btn--outline btn--small" data-notify-btn>Notify Me</button>
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}

        {%- comment -%} Trust row -- individual bordered cards {%- endcomment -%}
        <div class="pp-trust-row">
          <div class="pp-trust-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.8"><rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <div>
              <p class="pp-trust-title">Free Shipping</p>
              <p class="pp-trust-sub">Orders over $75</p>
            </div>
          </div>
          <div class="pp-trust-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            <div>
              <p class="pp-trust-title">100% Authentic</p>
              <p class="pp-trust-sub">Authorised seller</p>
            </div>
          </div>
          <div class="pp-trust-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.8"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            <div>
              <p class="pp-trust-title">Easy Returns</p>
              <p class="pp-trust-sub">14-day policy</p>
            </div>
          </div>
        </div>

        {%- comment -%} Payment icons {%- endcomment -%}
        {%- if section.settings.show_payment_icons -%}
          <div class="pp-payment-row">
            <span class="pp-payment-label">Safe checkout:</span>
            <div class="pp-payment-icons">
              {%- for type in shop.enabled_payment_types -%}
                {{ type | payment_type_svg_tag: class: 'payment-icon' }}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Accordions {%- endcomment -%}
        <div class="pp-accordions">
          {%- if product.description != blank -%}
            <details class="pp-accordion" open>
              <summary class="pp-accordion__title">
                <span>Description</span>
                <svg class="pp-accordion__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pp-accordion__body rte">{{ product.description }}</div>
            </details>
          {%- endif -%}

          {%- for block in accordion_blocks -%}
            <details class="pp-accordion" {{ block.shopify_attributes }}>
              <summary class="pp-accordion__title">
                <span>{{ block.settings.title }}</span>
                <svg class="pp-accordion__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pp-accordion__body rte">{{ block.settings.content }}</div>
            </details>
          {%- endfor -%}
        </div>

        {%- comment -%} Share {%- endcomment -%}
        <div class="pp-share">
          <span>Share:</span>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" class="pp-share-btn" aria-label="Share on Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" class="pp-share-btn" aria-label="Share on Twitter/X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
          </a>
          <a href="mailto:?subject={{ product.title | url_encode }}&body={{ shop.url }}{{ product.url }}" class="pp-share-btn" aria-label="Share by Email">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>

      </div>{%- comment -%}/.product-page__info{%- endcomment -%}
    </div>{%- comment -%}/.product-page{%- endcomment -%}

    {%- comment -%} ---
        PRODUCT TABS
    --- {%- endcomment -%}
    <div class="pp-section-divider"></div>

    <div class="pp-tabs" data-product-tabs id="pp-reviews-tab">
      <div class="pp-tabs__nav" role="tablist">
        <button class="pp-tab-btn is-active" role="tab" aria-selected="true" data-tab-target="description">
          Description
        </button>
        {%- if box_blocks.size > 0 -%}
          <button class="pp-tab-btn" role="tab" aria-selected="false" data-tab-target="contents">
            Box Contents
          </button>
        {%- endif -%}
        {%- if review_blocks.size > 0 or section.settings.show_rating -%}
          <button class="pp-tab-btn" role="tab" aria-selected="false" data-tab-target="reviews">
            Reviews ({{ section.settings.review_count | default: 0 }})
          </button>
        {%- endif -%}
      </div>

      <div class="pp-tabs__body">

        {%- comment -%} Description tab {%- endcomment -%}
        <div class="pp-tab-panel is-active" data-tab-panel="description" role="tabpanel">
          <div class="pp-tab-card rte">
            {%- if product.description != blank -%}
              {{ product.description }}
            {%- else -%}
              <p>No description available for this product.</p>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Box contents tab {%- endcomment -%}
        {%- if box_blocks.size > 0 -%}
          <div class="pp-tab-panel" data-tab-panel="contents" role="tabpanel">
            <div class="pp-tab-card">
              <h3 class="pp-tab-heading">What's Inside</h3>
              <div class="pp-box-list">
                {%- for block in box_blocks -%}
                  <div class="pp-box-item" {{ block.shopify_attributes }}>
                    <div class="pp-box-item__icon">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    </div>
                    <div class="pp-box-item__content">
                      <div class="pp-box-item__header">
                        <span class="pp-box-item__label">{{ block.settings.label }}</span>
                        <span class="pp-box-item__value">{{ block.settings.value }}</span>
                      </div>
                      {%- if block.settings.description != blank -%}
                        <p class="pp-box-item__desc">{{ block.settings.description }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endfor -%}
              </div>

              {%- if section.settings.show_pull_rates -%}
                <div class="pp-pull-rates">
                  <h4 class="pp-pull-rates__heading">Pull Rate Expectations</h4>
                  <p class="pp-pull-rates__note">{{ section.settings.pull_rates_note }}</p>
                  <div class="pp-pull-grid">
                    {%- assign pull_data = "Pokemon ex:6-8 cards,Full Art:2-4 cards,Illustration Rare:1-2 cards,Special Art Rare:0-1 cards,Gold / Hyper Rare:0-1 cards,Reverse Holo:36 cards" | split: "," -%}
                    {%- for item in pull_data -%}
                      {%- assign parts = item | split: ":" -%}
                      <div class="pp-pull-item">
                        <span class="pp-pull-item__label">{{ parts[0] }}</span>
                        <span class="pp-pull-item__value">{{ parts[1] }}</span>
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Reviews tab {%- endcomment -%}
        {%- if review_blocks.size > 0 or section.settings.show_rating -%}
          <div class="pp-tab-panel" data-tab-panel="reviews" role="tabpanel">
            <div class="pp-tab-card">
              {%- comment -%} Rating summary {%- endcomment -%}
              <div class="pp-review-summary">
                <div class="pp-review-score">
                  <span class="pp-review-score__num">{{ section.settings.review_score | default: '4.9' }}</span>
                  <div class="pp-stars">
                    {%- for i in (1..5) -%}
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    {%- endfor -%}
                  </div>
                  <span class="pp-review-score__count">{{ section.settings.review_count | default: 42 }} reviews</span>
                </div>
                <div class="pp-rating-bars">
                  {%- assign star_pcts = "91,6,2,1,0" | split: "," -%}
                  {%- for pct in star_pcts -%}
                    {%- assign star_num = 5 | minus: forloop.index0 -%}
                    <div class="pp-rating-bar-row">
                      <span class="pp-rating-bar-label">{{ star_num }}</span>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      <div class="pp-rating-bar-track">
                        <div class="pp-rating-bar-fill" style="width:{{ pct }}%"></div>
                      </div>
                      <span class="pp-rating-bar-pct">{{ pct }}%</span>
                    </div>
                  {%- endfor -%}
                </div>
              </div>

              {%- comment -%} Individual reviews {%- endcomment -%}
              {%- if review_blocks.size > 0 -%}
                <div class="pp-reviews-list">
                  {%- for block in review_blocks -%}
                    <div class="pp-review" {{ block.shopify_attributes }}>
                      <div class="pp-review__header">
                        <div>
                          <div class="pp-review__author-row">
                            <span class="pp-review__author">{{ block.settings.reviewer_name }}</span>
                            {%- if block.settings.verified -%}
                              <span class="pp-review__verified">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                                Verified
                              </span>
                            {%- endif -%}
                          </div>
                          <div class="pp-review__stars-row">
                            <div class="pp-stars pp-stars--sm">
                              {%- assign review_rating = block.settings.rating | default: 5 -%}
                              {%- for i in (1..5) -%}
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="{% if i <= review_rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                              {%- endfor -%}
                            </div>
                            <span class="pp-review__date">{{ block.settings.review_date }}</span>
                          </div>
                        </div>
                      </div>
                      <p class="pp-review__text">{{ block.settings.review_text }}</p>
                      {%- if block.settings.helpful_count > 0 -%}
                        <div class="pp-review__helpful">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                          Helpful ({{ block.settings.helpful_count }})
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>

    {%- comment -%} ---
        RECENT SALES TICKER
    --- {%- endcomment -%}
    {%- if sale_blocks.size > 0 -%}
      <div class="pp-section-divider"></div>
      <div class="pp-recent-sales">
        <h3 class="pp-recent-sales__heading">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Recent Sales
        </h3>
        <div class="pp-sales-list">
          {%- for block in sale_blocks -%}
            <div class="pp-sale-item" {{ block.shopify_attributes }}>
              <div class="pp-sale-item__info">
                <span class="pp-sale-item__name">{{ block.settings.product_name }}</span>
                <span class="pp-sale-item__time">{{ block.settings.time_ago }}</span>
              </div>
              <span class="pp-sale-item__price">{{ block.settings.price }}</span>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ---
        YOU MAY ALSO LIKE
    --- {%- endcomment -%}
    {%- if section.settings.show_related and collection != blank -%}
      {%- assign related = collection.products | where: 'available', true -%}
      {%- assign related_count = 0 -%}
      {%- assign related_limit = section.settings.related_count | default: 4 -%}

      {%- capture related_html -%}
        {%- for p in related -%}
          {%- unless p.id == product.id -%}
            {%- assign related_count = related_count | plus: 1 -%}
            {%- if related_count <= related_limit -%}
              {% render 'product-card', product: p, show_vendor: false, show_quick_view: true %}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- if related_count > 0 -%}
        <div class="pp-section-divider"></div>
        <div class="pp-related">
          <div class="pp-related__header">
            <h2 class="pp-related__heading">You May Also Like</h2>
            {%- if collection != blank -%}
              <a href="{{ collection.url }}" class="pp-related__link">View All</a>
            {%- endif -%}
          </div>
          <div class="product-grid product-grid--4">
            {{ related_html }}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | json }},
  "image": {{ product.featured_image | image_url: width: 800 | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "sku": {{ current_variant.sku | json }},
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ product.price | money_without_currency | json }},
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "seller": { "@type": "Organization", "name": {{ shop.name | json }} }
  }
}
</script>

{% schema %}
{
  "name": "Product page",
  "tag": "section",
  "class": "product-page-section",
  "settings": [
    { "type": "header", "content": "Pricing" },
    { "type": "checkbox", "id": "show_afterpay", "label": "Show Afterpay installment line", "default": true },
    { "type": "header", "content": "Urgency & social proof" },
    { "type": "range", "id": "low_stock_threshold", "label": "Low stock threshold", "min": 1, "max": 20, "step": 1, "default": 5 },
    { "type": "checkbox", "id": "show_viewing_now", "label": "Show 'X people viewing'", "default": true },
    { "type": "range", "id": "viewing_count", "label": "Default viewing count", "min": 2, "max": 50, "step": 1, "default": 8 },
    { "type": "header", "content": "Reviews" },
    { "type": "checkbox", "id": "show_rating", "label": "Show star rating", "default": true },
    { "type": "text", "id": "review_score", "label": "Average score (e.g. 4.9)", "default": "4.9" },
    { "type": "range", "id": "review_count", "label": "Review count", "min": 1, "max": 500, "step": 1, "default": 42 },
    { "type": "header", "content": "Box contents tab" },
    { "type": "checkbox", "id": "show_pull_rates", "label": "Show pull rates section", "default": false },
    { "type": "textarea", "id": "pull_rates_note", "label": "Pull rates note", "default": "While pull rates vary, a typical booster box from this set can yield the following on average:" },
    { "type": "header", "content": "Purchase options" },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout buttons", "default": true },
    { "type": "checkbox", "id": "show_notify", "label": "Show notify me (sold out)", "default": true },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true },
    { "type": "header", "content": "Related products" },
    { "type": "checkbox", "id": "show_related", "label": "Show related products", "default": true },
    { "type": "range", "id": "related_count", "label": "Number to show", "min": 2, "max": 8, "step": 2, "default": 4 }
  ],
  "blocks": [
    {
      "type": "detail_item",
      "name": "Product detail row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Set" },
        { "type": "text", "id": "value", "label": "Value", "default": "Obsidian Flames" }
      ]
    },
    {
      "type": "box_item",
      "name": "Box content row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Booster Packs" },
        { "type": "text", "id": "value", "label": "Value", "default": "36 packs" },
        { "type": "text", "id": "description", "label": "Description (optional)", "default": "Each pack contains 10 randomly assorted cards" }
      ]
    },
    {
      "type": "review",
      "name": "Customer review",
      "settings": [
        { "type": "text", "id": "reviewer_name", "label": "Reviewer name", "default": "Alex M." },
        { "type": "range", "id": "rating", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "review_date", "label": "Date", "default": "Feb 12, 2026" },
        { "type": "textarea", "id": "review_text", "label": "Review text", "default": "Amazing pull rates! Got two illustration rares and a gold card from this box. Arrived sealed and in perfect condition." },
        { "type": "checkbox", "id": "verified", "label": "Verified purchase", "default": true },
        { "type": "range", "id": "helpful_count", "label": "Helpful count", "min": 0, "max": 999, "step": 1, "default": 0 }
      ]
    },
    {
      "type": "recent_sale",
      "name": "Recent sale",
      "settings": [
        { "type": "text", "id": "product_name", "label": "Product name", "default": "Obsidian Flames Booster Box" },
        { "type": "text", "id": "price", "label": "Price (e.g. $144.99)", "default": "$144.99" },
        { "type": "text", "id": "time_ago", "label": "Time ago (e.g. 12 minutes ago)", "default": "12 minutes ago" }
      ]
    },
    {
      "type": "accordion",
      "name": "Info accordion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Shipping & Returns" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Orders ship within 1-2 business days. Free shipping on orders over $75. Easy 14-day returns on unopened product.</p>" }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [{ "name": "Product page" }]
}
{% endschema %}
