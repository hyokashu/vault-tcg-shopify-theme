{%- liquid
  assign product = product
  assign current_variant = product.selected_or_first_available_variant
  assign compare_price = product.compare_at_price
  assign sale_price = product.price
  assign on_sale = false
  if compare_price > sale_price
    assign on_sale = true
    assign savings_amount = compare_price | minus: sale_price
    assign savings_pct = savings_amount | times: 100 | divided_by: compare_price
  endif
  assign low_stock_threshold = section.settings.low_stock_threshold | default: 5
  assign inventory = current_variant.inventory_quantity
  assign track_inventory = current_variant.inventory_management

  assign detail_blocks = section.blocks | where: 'type', 'detail_item'
  assign box_blocks    = section.blocks | where: 'type', 'box_item'
  assign review_blocks = section.blocks | where: 'type', 'review'
  assign sale_blocks   = section.blocks | where: 'type', 'recent_sale'
  assign accordion_blocks = section.blocks | where: 'type', 'accordion'
-%}

{%- comment -%} Recently viewed tracking {%- endcomment -%}
<span data-product-handle="{{ product.handle }}" style="display:none" aria-hidden="true"></span>

{%- comment -%} ─── STICKY MOBILE ATC ─── {%- endcomment -%}
<div class="sticky-atc" data-sticky-atc aria-hidden="true">
  <div class="sticky-atc__inner container">
    <div class="sticky-atc__info">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 80 }}" alt="{{ product.title }}" width="40" height="40" class="sticky-atc__img">
      {%- endif -%}
      <div>
        <p class="sticky-atc__title" data-sticky-atc-title>{{ product.title | truncate: 40 }}</p>
        <p class="sticky-atc__price" data-sticky-atc-price>{{ current_variant.price | money }}</p>
      </div>
    </div>
    <button class="btn btn--primary btn--small sticky-atc__btn" data-sticky-atc-btn>
      Add to Cart
    </button>
  </div>
</div>

<div class="product-layout section-spacing">
  <div class="container">

    {%- comment -%} ─── BREADCRUMBS ─── {%- endcomment -%}
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span aria-hidden="true">/</span>
      {%- endif -%}
      <span aria-current="page">{{ product.title | truncate: 50 }}</span>
    </nav>

    <div class="product-page">

      {%- comment -%} ═══════════════════════════════════════════
          GALLERY
      ═══════════════════════════════════════════ {%- endcomment -%}
      <div class="product-page__gallery">

        <div class="product-page__gallery-wrap">
          {%- comment -%} Badges {%- endcomment -%}
          <div class="product-page__gallery-badges">
            {%- if on_sale -%}
              <span class="pp-badge pp-badge--sale">-{{ savings_pct }}%</span>
            {%- endif -%}
            {%- if product.tags contains 'new' or product.tags contains 'New' -%}
              <span class="pp-badge pp-badge--new">NEW</span>
            {%- endif -%}
            {%- if track_inventory == 'shopify' and inventory <= low_stock_threshold and inventory > 0 -%}
              <span class="pp-badge pp-badge--low">Low Stock</span>
            {%- endif -%}
          </div>

          {%- comment -%} Main image {%- endcomment -%}
          <div class="product-page__main-image" data-product-gallery>
            {%- if product.images.size > 0 -%}
              {%- for image in product.images -%}
                <div class="product-page__image-slide{% if forloop.first %} is-active{% endif %}" data-image-slide="{{ forloop.index0 }}">
                  <img
                    src="{{ image | image_url: width: 800 }}"
                    srcset="{{ image | image_url: width: 500 }} 500w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1100 }} 1100w"
                    sizes="(max-width: 768px) 100vw, 50vw"
                    alt="{{ image.alt | default: product.title }}"
                    width="800"
                    height="{{ 800 | divided_by: image.aspect_ratio | round }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    class="product-page__img"
                  >
                </div>
              {%- endfor -%}
            {%- else -%}
              <div class="product-page__image-slide is-active">
                {% render 'placeholder-pack-art', color_from: '#7C3AED', color_to: '#06B6D4', index: 1 %}
              </div>
            {%- endif -%}

            {%- if product.images.size > 1 -%}
              <button class="pp-gallery-arrow pp-gallery-arrow--prev" data-gallery-prev aria-label="Previous image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="pp-gallery-arrow pp-gallery-arrow--next" data-gallery-next aria-label="Next image">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
              <div class="pp-gallery-counter" aria-hidden="true">
                <span data-image-current>1</span> / {{ product.images.size }}
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Thumbnail strip {%- endcomment -%}
          {%- if product.images.size > 1 -%}
            <div class="product-page__thumbs">
              {%- for image in product.images -%}
                <button
                  class="product-page__thumb{% if forloop.first %} is-active{% endif %}"
                  data-thumb-index="{{ forloop.index0 }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  <img src="{{ image | image_url: width: 160 }}" alt="" width="80" height="80" loading="lazy">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ═══════════════════════════════════════════
          PRODUCT INFO
      ═══════════════════════════════════════════ {%- endcomment -%}
      <div class="product-page__info">

        {%- comment -%} Status badges {%- endcomment -%}
        <div class="pp-status-badges">
          <span class="pp-status-badge pp-status-badge--sealed">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            Sealed
          </span>
          <span class="pp-status-badge pp-status-badge--auth">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            Authentic
          </span>
          {%- if track_inventory == 'shopify' and inventory <= low_stock_threshold and inventory > 0 -%}
            <span class="pp-status-badge pp-status-badge--low">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
              Only {{ inventory }} left
            </span>
          {%- endif -%}
        </div>

        {%- comment -%} Title {%- endcomment -%}
        <h1 class="pp-title">{{ product.title }}</h1>

        {%- comment -%} Vendor / type {%- endcomment -%}
        {%- if product.vendor != blank or product.type != blank -%}
          <div class="pp-meta-row">
            {%- if product.vendor != blank -%}
              <a href="{{ product.vendor | url_for_vendor }}" class="pp-meta-link">{{ product.vendor }}</a>
            {%- endif -%}
            {%- if product.type != blank -%}
              <span class="pp-meta-tag">{{ product.type }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} Star rating {%- endcomment -%}
        {%- if section.settings.show_rating -%}
          <div class="pp-rating-row">
            <div class="pp-stars" aria-label="4.9 out of 5 stars">
              {%- for i in (1..5) -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endfor -%}
            </div>
            <a href="#pp-reviews-tab" class="pp-rating-link" data-tab-jump="reviews">
              {{ section.settings.review_count | default: 42 }} reviews
            </a>
            <span class="pp-rating-sep">·</span>
            {%- if section.settings.show_viewing_now -%}
              <span class="pp-viewing">
                <span class="pp-viewing-dot"></span>
                <span data-viewing-count>{{ section.settings.viewing_count | default: 8 }} viewing</span>
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="pp-divider"></div>

        {%- comment -%} Price block {%- endcomment -%}
        <div class="pp-price-block">
          <div class="pp-price-row">
            {%- if on_sale -%}
              <span class="pp-price pp-price--sale" data-sticky-atc-price>{{ sale_price | money }}</span>
              <span class="pp-price-compare">{{ compare_price | money }}</span>
              <span class="pp-price-save">Save {{ savings_amount | money }}</span>
            {%- else -%}
              <span class="pp-price" data-sticky-atc-price>{{ sale_price | money }}</span>
            {%- endif -%}
          </div>

          {%- if section.settings.show_afterpay -%}
            {%- assign installment_price = sale_price | divided_by: 4 -%}
            <p class="pp-afterpay">
              or 4 interest-free payments of <strong>{{ installment_price | money }}</strong> with <strong>Afterpay</strong>
            </p>
          {%- endif -%}

          <p class="pp-price-note">
            {%- if cart.taxes_included -%}Tax included. {%- endif -%}
            {%- if shop.shipping_policy.body != blank -%}
              <a href="{{ shop.shipping_policy.url }}">Shipping</a> calculated at checkout.
            {%- endif -%}
          </p>
        </div>

        <div class="pp-divider"></div>

        {%- comment -%} Product details grid {%- endcomment -%}
        {%- if detail_blocks.size > 0 -%}
          <div class="pp-detail-grid">
            {%- for block in detail_blocks -%}
              <div class="pp-detail-item" {{ block.shopify_attributes }}>
                <span class="pp-detail-label">{{ block.settings.label }}</span>
                <span class="pp-detail-value">{{ block.settings.value }}</span>
              </div>
            {%- endfor -%}
          </div>
          <div class="pp-divider"></div>
        {%- endif -%}

        {%- comment -%} Stock + urgency {%- endcomment -%}
        <div class="pp-urgency-row">
          {%- if product.available -%}
            {%- if track_inventory == 'shopify' and inventory <= low_stock_threshold and inventory > 0 -%}
              <div class="pp-stock pp-stock--low">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
                Only {{ inventory }} left — order soon!
              </div>
              <div class="pp-stock-bar-wrap">
                {%- assign bar_pct = inventory | times: 100 | divided_by: low_stock_threshold -%}
                <div class="pp-stock-bar"><div class="pp-stock-bar-fill" style="width:{{ bar_pct }}%"></div></div>
                <span class="pp-stock-bar-label">Selling fast</span>
              </div>
            {%- else -%}
              <div class="pp-stock pp-stock--in">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                In Stock &amp; Ready to Ship
              </div>
            {%- endif -%}
          {%- else -%}
            <div class="pp-stock pp-stock--out">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
              Sold Out
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Variant selectors + form {%- endcomment -%}
        {%- form 'product', product, data-product-form: '', data-product-id: product.id -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          {%- unless product.has_only_default_variant -%}
            <div class="pp-variants">
              {%- for option in product.options_with_values -%}
                <div class="pp-option">
                  <label class="pp-option-label">
                    {{ option.name }}: <strong>{{ option.selected_value }}</strong>
                  </label>
                  <div class="pp-option-values">
                    {%- for value in option.values -%}
                      <label class="pp-swatch{% if option.selected_value == value %} is-selected{% endif %}">
                        <input
                          type="radio"
                          name="option{{ forloop.index0 }}"
                          value="{{ value | escape }}"
                          class="visually-hidden"
                          data-option-index="{{ forloop.index0 }}"
                          {% if option.selected_value == value %}checked{% endif %}
                        >
                        {{ value }}
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
              <select name="id" class="visually-hidden" data-variant-select>
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {% if variant == current_variant %}selected{% endif %}
                    {% unless variant.available %}disabled{% endunless %}
                    data-price="{{ variant.price }}"
                    data-compare-price="{{ variant.compare_at_price }}"
                  >{{ variant.title }} — {{ variant.price | money }}</option>
                {%- endfor -%}
              </select>
            </div>
          {%- endunless -%}

          {%- comment -%} Buy box {%- endcomment -%}
          {%- if product.available -%}
            <div class="pp-buy-box">
              <div class="pp-qty">
                <button type="button" class="pp-qty-btn" data-qty-minus aria-label="Decrease quantity">−</button>
                <input type="number" name="quantity" value="1" min="1" max="99" class="pp-qty-input" data-qty-input aria-label="Quantity">
                <button type="button" class="pp-qty-btn" data-qty-plus aria-label="Increase quantity">+</button>
              </div>
              <button type="submit" class="btn btn--primary btn--large pp-atc-btn" data-add-to-cart>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                <span data-add-to-cart-text>Add to Cart</span>
              </button>
              <button type="button" class="pp-wishlist-btn" data-wishlist-btn aria-label="Save to wishlist">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-wishlist-icon><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              </button>
            </div>

            {%- if section.settings.show_dynamic_checkout -%}
              <div class="pp-dynamic-checkout">
                {{ form | payment_button }}
              </div>
            {%- endif -%}
          {%- else -%}
            <div class="pp-buy-box">
              <button class="btn btn--outline btn--large" disabled style="flex:1;opacity:.5">Sold Out</button>
            </div>
            {%- if section.settings.show_notify -%}
              <div class="pp-notify">
                <p>Want to know when this is back?</p>
                <button class="btn btn--outline btn--small" data-notify-btn>Notify Me</button>
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endform -%}

        {%- comment -%} Trust row — individual bordered cards {%- endcomment -%}
        <div class="pp-trust-row">
          <div class="pp-trust-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.8"><rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <div>
              <p class="pp-trust-title">Free Shipping</p>
              <p class="pp-trust-sub">Orders over $75</p>
            </div>
          </div>
          <div class="pp-trust-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            <div>
              <p class="pp-trust-title">100% Authentic</p>
              <p class="pp-trust-sub">Authorised seller</p>
            </div>
          </div>
          <div class="pp-trust-card">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="1.8"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            <div>
              <p class="pp-trust-title">Easy Returns</p>
              <p class="pp-trust-sub">14-day policy</p>
            </div>
          </div>
        </div>

        {%- comment -%} Payment icons {%- endcomment -%}
        {%- if section.settings.show_payment_icons -%}
          <div class="pp-payment-row">
            <span class="pp-payment-label">Safe checkout:</span>
            <div class="pp-payment-icons">
              {%- for type in shop.enabled_payment_types -%}
                {{ type | payment_type_svg_tag: class: 'payment-icon' }}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Accordions {%- endcomment -%}
        <div class="pp-accordions">
          {%- if product.description != blank -%}
            <details class="pp-accordion" open>
              <summary class="pp-accordion__title">
                <span>Description</span>
                <svg class="pp-accordion__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pp-accordion__body rte">{{ product.description }}</div>
            </details>
          {%- endif -%}

          {%- for block in accordion_blocks -%}
            <details class="pp-accordion" {{ block.shopify_attributes }}>
              <summary class="pp-accordion__title">
                <span>{{ block.settings.title }}</span>
                <svg class="pp-accordion__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pp-accordion__body rte">{{ block.settings.content }}</div>
            </details>
          {%- endfor -%}
        </div>

        {%- comment -%} Share {%- endcomment -%}
        <div class="pp-share">
          <span>Share:</span>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener" class="pp-share-btn" aria-label="Share on Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_encode }}" target="_blank" rel="noopener" class="pp-share-btn" aria-label="Share on Twitter/X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
          </a>
          <a href="mailto:?subject={{ product.title | url_encode }}&body={{ shop.url }}{{ product.url }}" class="pp-share-btn" aria-label="Share by Email">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        </div>

      </div>{%- comment -%}/.product-page__info{%- endcomment -%}
    </div>{%- comment -%}/.product-page{%- endcomment -%}

    {%- comment -%} ═══════════════════════════════════════════
        PRODUCT TABS
    ═══════════════════════════════════════════ {%- endcomment -%}
    <div class="pp-section-divider"></div>

    <div class="pp-tabs" data-product-tabs id="pp-reviews-tab">
      <div class="pp-tabs__nav" role="tablist">
        <button class="pp-tab-btn is-active" role="tab" aria-selected="true" data-tab-target="description">
          Description
        </button>
        {%- if box_blocks.size > 0 -%}
          <button class="pp-tab-btn" role="tab" aria-selected="false" data-tab-target="contents">
            Box Contents
          </button>
        {%- endif -%}
        {%- if review_blocks.size > 0 or section.settings.show_rating -%}
          <button class="pp-tab-btn" role="tab" aria-selected="false" data-tab-target="reviews">
            Reviews ({{ section.settings.review_count | default: 0 }})
          </button>
        {%- endif -%}
      </div>

      <div class="pp-tabs__body">

        {%- comment -%} Description tab {%- endcomment -%}
        <div class="pp-tab-panel is-active" data-tab-panel="description" role="tabpanel">
          <div class="pp-tab-card rte">
            {%- if product.description != blank -%}
              {{ product.description }}
            {%- else -%}
              <p>No description available for this product.</p>
            {%- endif -%}
          </div>
        </div>

        {%- comment -%} Box contents tab {%- endcomment -%}
        {%- if box_blocks.size > 0 -%}
          <div class="pp-tab-panel" data-tab-panel="contents" role="tabpanel">
            <div class="pp-tab-card">
              <h3 class="pp-tab-heading">What's Inside</h3>
              <div class="pp-box-list">
                {%- for block in box_blocks -%}
                  <div class="pp-box-item" {{ block.shopify_attributes }}>
                    <div class="pp-box-item__icon">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    </div>
                    <div class="pp-box-item__content">
                      <div class="pp-box-item__header">
                        <span class="pp-box-item__label">{{ block.settings.label }}</span>
                        <span class="pp-box-item__value">{{ block.settings.value }}</span>
                      </div>
                      {%- if block.settings.description != blank -%}
                        <p class="pp-box-item__desc">{{ block.settings.description }}</p>
                      {%- endif -%}
                    </div>
                  </div>
                {%- endfor -%}
              </div>

              {%- if section.settings.show_pull_rates -%}
                <div class="pp-pull-rates">
                  <h4 class="pp-pull-rates__heading">Pull Rate Expectations</h4>
                  <p class="pp-pull-rates__note">{{ section.settings.pull_rates_note }}</p>
                  <div class="pp-pull-grid">
                    {%- assign pull_data = "Pokemon ex:6–8 cards,Full Art:2–4 cards,Illustration Rare:1–2 cards,Special Art Rare:0–1 cards,Gold / Hyper Rare:0–1 cards,Reverse Holo:36 cards" | split: "," -%}
                    {%- for item in pull_data -%}
                      {%- assign parts = item | split: ":" -%}
                      <div class="pp-pull-item">
                        <span class="pp-pull-item__label">{{ parts[0] }}</span>
                        <span class="pp-pull-item__value">{{ parts[1] }}</span>
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} Reviews tab {%- endcomment -%}
        {%- if review_blocks.size > 0 or section.settings.show_rating -%}
          <div class="pp-tab-panel" data-tab-panel="reviews" role="tabpanel">
            <div class="pp-tab-card">
              {%- comment -%} Rating summary {%- endcomment -%}
              <div class="pp-review-summary">
                <div class="pp-review-score">
                  <span class="pp-review-score__num">{{ section.settings.review_score | default: '4.9' }}</span>
                  <div class="pp-stars">
                    {%- for i in (1..5) -%}
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    {%- endfor -%}
                  </div>
                  <span class="pp-review-score__count">{{ section.settings.review_count | default: 42 }} reviews</span>
                </div>
                <div class="pp-rating-bars">
                  {%- assign star_pcts = "91,6,2,1,0" | split: "," -%}
                  {%- for pct in star_pcts -%}
                    {%- assign star_num = 5 | minus: forloop.index0 -%}
                    <div class="pp-rating-bar-row">
                      <span class="pp-rating-bar-label">{{ star_num }}</span>
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      <div class="pp-rating-bar-track">
                        <div class="pp-rating-bar-fill" style="width:{{ pct }}%"></div>
                      </div>
                      <span class="pp-rating-bar-pct">{{ pct }}%</span>
                    </div>
                  {%- endfor -%}
                </div>
              </div>

              {%- comment -%} Individual reviews {%- endcomment -%}
              {%- if review_blocks.size > 0 -%}
                <div class="pp-reviews-list">
                  {%- for block in review_blocks -%}
                    <div class="pp-review" {{ block.shopify_attributes }}>
                      <div class="pp-review__header">
                        <div>
                          <div class="pp-review__author-row">
                            <span class="pp-review__author">{{ block.settings.reviewer_name }}</span>
                            {%- if block.settings.verified -%}
                              <span class="pp-review__verified">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                                Verified
                              </span>
                            {%- endif -%}
                          </div>
                          <div class="pp-review__stars-row">
                            <div class="pp-stars pp-stars--sm">
                              {%- assign review_rating = block.settings.rating | default: 5 -%}
                              {%- for i in (1..5) -%}
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="{% if i <= review_rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                              {%- endfor -%}
                            </div>
                            <span class="pp-review__date">{{ block.settings.review_date }}</span>
                          </div>
                        </div>
                      </div>
                      <p class="pp-review__text">{{ block.settings.review_text }}</p>
                      {%- if block.settings.helpful_count > 0 -%}
                        <div class="pp-review__helpful">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                          Helpful ({{ block.settings.helpful_count }})
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>
    </div>

    {%- comment -%} ═══════════════════════════════════════════
        RECENT SALES TICKER
    ═══════════════════════════════════════════ {%- endcomment -%}
    {%- if sale_blocks.size > 0 -%}
      <div class="pp-section-divider"></div>
      <div class="pp-recent-sales">
        <h3 class="pp-recent-sales__heading">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Recent Sales
        </h3>
        <div class="pp-sales-list">
          {%- for block in sale_blocks -%}
            <div class="pp-sale-item" {{ block.shopify_attributes }}>
              <div class="pp-sale-item__info">
                <span class="pp-sale-item__name">{{ block.settings.product_name }}</span>
                <span class="pp-sale-item__time">{{ block.settings.time_ago }}</span>
              </div>
              <span class="pp-sale-item__price">{{ block.settings.price }}</span>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ═══════════════════════════════════════════
        YOU MAY ALSO LIKE
    ═══════════════════════════════════════════ {%- endcomment -%}
    {%- if section.settings.show_related and collection != blank -%}
      {%- assign related = collection.products | where: 'available', true -%}
      {%- assign related_count = 0 -%}
      {%- assign related_limit = section.settings.related_count | default: 4 -%}

      {%- capture related_html -%}
        {%- for p in related -%}
          {%- unless p.id == product.id -%}
            {%- assign related_count = related_count | plus: 1 -%}
            {%- if related_count <= related_limit -%}
              {% render 'product-card', product: p, show_vendor: false, show_quick_view: true %}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- if related_count > 0 -%}
        <div class="pp-section-divider"></div>
        <div class="pp-related">
          <div class="pp-related__header">
            <h2 class="pp-related__heading">You May Also Like</h2>
            {%- if collection != blank -%}
              <a href="{{ collection.url }}" class="pp-related__link">View All</a>
            {%- endif -%}
          </div>
          <div class="product-grid product-grid--4">
            {{ related_html }}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | json }},
  "image": {{ product.featured_image | image_url: width: 800 | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "sku": {{ current_variant.sku | json }},
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ product.price | money_without_currency | json }},
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "seller": { "@type": "Organization", "name": {{ shop.name | json }} }
  }
}
</script>

{% schema %}
{
  "name": "Product page",
  "tag": "section",
  "class": "product-page-section",
  "settings": [
    { "type": "header", "content": "Pricing" },
    { "type": "checkbox", "id": "show_afterpay", "label": "Show Afterpay installment line", "default": true },
    { "type": "header", "content": "Urgency & social proof" },
    { "type": "range", "id": "low_stock_threshold", "label": "Low stock threshold", "min": 1, "max": 20, "step": 1, "default": 5 },
    { "type": "checkbox", "id": "show_viewing_now", "label": "Show 'X people viewing'", "default": true },
    { "type": "range", "id": "viewing_count", "label": "Default viewing count", "min": 2, "max": 50, "step": 1, "default": 8 },
    { "type": "header", "content": "Reviews" },
    { "type": "checkbox", "id": "show_rating", "label": "Show star rating", "default": true },
    { "type": "text", "id": "review_score", "label": "Average score (e.g. 4.9)", "default": "4.9" },
    { "type": "range", "id": "review_count", "label": "Review count", "min": 1, "max": 9999, "step": 1, "default": 42 },
    { "type": "header", "content": "Box contents tab" },
    { "type": "checkbox", "id": "show_pull_rates", "label": "Show pull rates section", "default": false },
    { "type": "textarea", "id": "pull_rates_note", "label": "Pull rates note", "default": "While pull rates vary, a typical booster box from this set can yield the following on average:" },
    { "type": "header", "content": "Purchase options" },
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Show dynamic checkout buttons", "default": true },
    { "type": "checkbox", "id": "show_notify", "label": "Show notify me (sold out)", "default": true },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Show payment icons", "default": true },
    { "type": "header", "content": "Related products" },
    { "type": "checkbox", "id": "show_related", "label": "Show related products", "default": true },
    { "type": "range", "id": "related_count", "label": "Number to show", "min": 2, "max": 8, "step": 2, "default": 4 }
  ],
  "blocks": [
    {
      "type": "detail_item",
      "name": "Product detail row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Set" },
        { "type": "text", "id": "value", "label": "Value", "default": "Obsidian Flames" }
      ]
    },
    {
      "type": "box_item",
      "name": "Box content row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Booster Packs" },
        { "type": "text", "id": "value", "label": "Value", "default": "36 packs" },
        { "type": "text", "id": "description", "label": "Description (optional)", "default": "Each pack contains 10 randomly assorted cards" }
      ]
    },
    {
      "type": "review",
      "name": "Customer review",
      "settings": [
        { "type": "text", "id": "reviewer_name", "label": "Reviewer name", "default": "Alex M." },
        { "type": "range", "id": "rating", "label": "Star rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "review_date", "label": "Date", "default": "Feb 12, 2026" },
        { "type": "textarea", "id": "review_text", "label": "Review text", "default": "Amazing pull rates! Got two illustration rares and a gold card from this box. Arrived sealed and in perfect condition." },
        { "type": "checkbox", "id": "verified", "label": "Verified purchase", "default": true },
        { "type": "range", "id": "helpful_count", "label": "Helpful count", "min": 0, "max": 999, "step": 1, "default": 0 }
      ]
    },
    {
      "type": "recent_sale",
      "name": "Recent sale",
      "settings": [
        { "type": "text", "id": "product_name", "label": "Product name", "default": "Obsidian Flames Booster Box" },
        { "type": "text", "id": "price", "label": "Price (e.g. $144.99)", "default": "$144.99" },
        { "type": "text", "id": "time_ago", "label": "Time ago (e.g. 12 minutes ago)", "default": "12 minutes ago" }
      ]
    },
    {
      "type": "accordion",
      "name": "Info accordion",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Shipping & Returns" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Orders ship within 1–2 business days. Free shipping on orders over $75. Easy 14-day returns on unopened product.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "Product page" }]
}
{% endschema %}
