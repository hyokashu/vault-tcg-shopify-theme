{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="product-layout section-spacing">
  <div class="container">
    <h1 style="font-size:2rem;margin-bottom:16px">{{ product.title }}</h1>
    <p style="font-size:1.4rem;margin-bottom:24px">{{ current_variant.price | money }}</p>
    {%- form 'product', product -%}
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      <button type="submit" style="background:#7C3AED;color:#fff;padding:14px 28px;border-radius:8px;border:none;font-size:1rem;cursor:pointer">
        Add to Cart
      </button>
    {%- endform -%}
    {% if product.description != blank %}
      <div style="margin-top:24px">{{ product.description }}</div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Product page",
  "settings": [],
  "blocks": [],
  "presets": [{ "name": "Product page" }]
}
{% endschema %}
