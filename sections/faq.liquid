<div class="section-spacing">
  <div class="container container--narrow">
    <div class="section-header section-header--center">
      {%- if section.settings.tag != blank -%}
        <span class="section-tag">{{ section.settings.tag }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="section-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="faq-list" role="list">
      {%- for block in section.blocks -%}
        <details class="faq-item" {{ block.shopify_attributes }}>
          <summary class="faq-item__question">
            <span>{{ block.settings.question }}</span>
            <svg class="faq-item__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </summary>
          <div class="faq-item__answer rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>

    {%- if section.settings.contact_text != blank -%}
      <div class="faq-contact">
        <p>{{ section.settings.contact_text }}</p>
        {%- if section.settings.contact_link != blank -%}
          <a href="{{ section.settings.contact_link }}" class="btn btn--outline">{{ section.settings.contact_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "faq-section",
  "settings": [
    {
      "type": "text",
      "id": "tag",
      "label": "Tag line",
      "default": "❓ FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact prompt text",
      "default": "Still have questions?"
    },
    {
      "type": "text",
      "id": "contact_label",
      "label": "Contact button label",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Contact link"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Are all products factory sealed?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Yes! Every product we sell is 100% factory sealed and sourced directly from authorized distributors. We never sell resealed or tampered products.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "Are all products factory sealed?",
            "answer": "<p>Yes! Every product we sell is 100% factory sealed and sourced directly from authorized distributors. We never sell resealed or tampered products.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "How fast do you ship?",
            "answer": "<p>Orders placed before 2 PM EST ship same day. Standard shipping is 3-5 business days. Express and overnight options are available at checkout.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Do you offer returns?",
            "answer": "<p>We accept returns within 14 days of delivery for unopened, sealed products in their original condition. Once a product is opened, we cannot accept returns.</p>"
          }
        },
        {
          "type": "question",
          "settings": {
            "question": "Are your prices competitive?",
            "answer": "<p>We work directly with distributors to offer the best prices possible. If you find a lower price from an authorized seller, reach out and we'll do our best to match it.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
