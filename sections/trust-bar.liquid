<div class="trust-bar" data-section-id="{{ section.id }}">
  <div class="container">
    <ul class="trust-bar__list" role="list">
      {%- for block in section.blocks -%}
        <li class="trust-bar__item" {{ block.shopify_attributes }}>
          <span class="trust-bar__icon">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'shield' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {%- when 'refresh' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
              {%- when 'star' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- when 'lock' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              {%- when 'box' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            {%- endcase -%}
          </span>
          <div class="trust-bar__text">
            <strong class="trust-bar__title">{{ block.settings.title }}</strong>
            {%- if block.settings.subtitle != blank -%}
              <span class="trust-bar__subtitle">{{ block.settings.subtitle }}</span>
            {%- endif -%}
          </div>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Trust bar",
  "tag": "section",
  "class": "trust-bar-section",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "truck",
          "options": [
            { "value": "truck", "label": "Truck" },
            { "value": "shield", "label": "Shield / Auth" },
            { "value": "refresh", "label": "Returns" },
            { "value": "star", "label": "Rating" },
            { "value": "lock", "label": "Secure" },
            { "value": "box", "label": "Box / Sealed" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Free Shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "On orders over $75" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "truck", "title": "Free Shipping", "subtitle": "On orders over $75" } },
        { "type": "trust_item", "settings": { "icon": "shield", "title": "100% Authentic", "subtitle": "Authorised distributor" } },
        { "type": "trust_item", "settings": { "icon": "box", "title": "Factory Sealed", "subtitle": "Guaranteed unopened" } },
        { "type": "trust_item", "settings": { "icon": "refresh", "title": "Easy Returns", "subtitle": "14-day return policy" } }
      ]
    }
  ]
}
{% endschema %}
