{%- if section.settings.show_announcement -%}
<div class="announcement-bar" data-section-id="{{ section.id }}" role="region" aria-label="{{ 'accessibility.announcement' | t }}">
  <div class="container">
    <div class="announcement-bar__inner">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__link">
      {%- endif -%}

      <p class="announcement-bar__text">
        {%- if section.settings.icon != 'none' -%}
          <span class="announcement-bar__icon">
            {%- case section.settings.icon -%}
              {%- when 'truck' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'tag' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              {%- when 'star' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- when 'zap' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            {%- endcase -%}
          </span>
        {%- endif -%}
        {{ section.settings.text }}
      </p>

      {%- if section.settings.link != blank -%}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "🔥 Free shipping on orders over $75 — New drops every Friday!"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "default": "zap",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "truck", "label": "Shipping truck" },
        { "value": "tag", "label": "Sale tag" },
        { "value": "star", "label": "Star" },
        { "value": "zap", "label": "Lightning bolt" }
      ]
    }
  ]
}
{% endschema %}
