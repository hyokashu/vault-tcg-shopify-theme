<div class="value-strip">
  <div class="container">
    <div class="value-strip__grid">
      {%- for block in section.blocks -%}
        <div class="value-prop" {{ block.shopify_attributes }}>
          <div class="value-prop__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'factory' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/></svg>
              {%- when 'shield' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              {%- when 'stadium' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
              {%- when 'wrench' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.670 4.670m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/></svg>
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/></svg>
            {%- endcase -%}
          </div>
          <div class="value-prop__stat">{{ block.settings.stat }}</div>
          <div class="value-prop__name">{{ block.settings.name }}</div>
          <div class="value-prop__desc">{{ block.settings.description }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Value props strip",
  "tag": "section",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "prop",
      "name": "Value proposition",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
            { "value": "factory", "label": "Factory / Manufacturing" },
            { "value": "shield", "label": "Shield / Certification" },
            { "value": "stadium", "label": "Stadium / Venue" },
            { "value": "wrench", "label": "Wrench / Warranty" },
            { "value": "truck", "label": "Truck / Delivery" }
          ], "default": "shield" },
        { "type": "text", "id": "stat", "label": "Statistic or headline", "default": "30+" },
        { "type": "text", "id": "name", "label": "Short label", "default": "Years Manufacturing" },
        { "type": "text", "id": "description", "label": "Description", "default": "Australian made since 1992" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value props strip",
      "blocks": [
        { "type": "prop", "settings": { "icon": "factory", "stat": "30+", "name": "Years Manufacturing", "description": "Australian made since 1992" } },
        { "type": "prop", "settings": { "icon": "shield", "stat": "AS", "name": "Certified", "description": "Meets all Australian Standards" } },
        { "type": "prop", "settings": { "icon": "stadium", "stat": "500+", "name": "Venues Installed", "description": "Premier venues nationwide" } },
        { "type": "prop", "settings": { "icon": "wrench", "stat": "5yr", "name": "Guarantee", "description": "Structural warranty on all goals" } },
        { "type": "prop", "settings": { "icon": "truck", "stat": "AU", "name": "Nationwide", "description": "Delivery & installation across Australia" } }
      ]
    }
  ]
}
{% endschema %}
