<section class="authority-strip">
  <div class="container">
    <p class="authority-strip__label">{{ section.settings.label | default: "Trusted by Australia's Premier Venues & Governing Bodies" }}</p>
    <div class="authority-strip__logos">
      {%- for block in section.blocks -%}
        {%- if block.settings.logo != blank -%}
          <img
            src="{{ block.settings.logo | image_url: width: 200 }}"
            alt="{{ block.settings.name | escape }}"
            class="authority-logo"
            width="120" height="40"
            loading="lazy">
        {%- else -%}
          <span class="authority-logo-placeholder">{{ block.settings.name }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Authority / Partner logos",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    { "type": "text", "id": "label", "label": "Strip label text", "default": "Trusted by Australia's Premier Venues & Governing Bodies" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Partner logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo image" },
        { "type": "text", "id": "name", "label": "Partner name (alt text / placeholder)", "default": "AFL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Authority / Partner logos",
      "blocks": [
        { "type": "logo", "settings": { "name": "AFL" } },
        { "type": "logo", "settings": { "name": "Football Australia" } },
        { "type": "logo", "settings": { "name": "NRL" } },
        { "type": "logo", "settings": { "name": "Rugby Australia" } },
        { "type": "logo", "settings": { "name": "MCG" } },
        { "type": "logo", "settings": { "name": "ANZ Stadium" } }
      ]
    }
  ]
}
{% endschema %}
