<section class="section section--tint">
  <div class="container">
    <div class="section__header">
      <p class="eyebrow">{{ section.settings.eyebrow | default: 'Technical Resources' }}</p>
      <h2 class="section__title">{{ section.settings.heading | default: 'Specifications & Downloads' }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section__subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.show_filters -%}
      <div class="product-grid__filters" role="group" aria-label="Filter resources">
        <button class="filter-pill active" data-filter="all">All Resources</button>
        {%- for cat in section.settings.categories | split: ',' -%}
          <button class="filter-pill" data-filter="{{ cat | strip | handle }}">{{ cat | strip }}</button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="resources__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.file_url | default: '#' }}" class="resource-card" download target="_blank" rel="noopener" {{ block.shopify_attributes }} aria-label="Download {{ block.settings.title }}">
          <div class="resource-card__icon" aria-hidden="true">
            {%- case block.settings.resource_type -%}
              {%- when 'pdf' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
              {%- when 'cad' -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
              {%- else -%}
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
            {%- endcase -%}
          </div>
          <div class="resource-card__content">
            <div class="resource-card__cat">{{ block.settings.category }}</div>
            <div class="resource-card__title">{{ block.settings.title }}</div>
            <div class="resource-card__meta">{{ block.settings.file_size | default: 'PDF' }}{%- if block.settings.standard != blank %} &middot; {{ block.settings.standard }}{%- endif -%}</div>
          </div>
          <div class="resource-card__dl" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Resources / Downloads",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Technical Resources" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Specifications & Downloads" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Download spec sheets, installation guides, and Australian Standards documentation for your tender requirements." },
    { "type": "checkbox", "id": "show_filters", "label": "Show category filters", "default": true },
    { "type": "text", "id": "categories", "label": "Filter categories (comma separated)", "default": "AFL, Soccer, Rugby, Flagpoles, Installation Guides" }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Download resource",
      "settings": [
        { "type": "select", "id": "resource_type", "label": "Resource type", "options": [
            { "value": "pdf", "label": "PDF / Spec Sheet" },
            { "value": "cad", "label": "CAD Drawing" },
            { "value": "download", "label": "Other Download" }
          ], "default": "pdf" },
        { "type": "text", "id": "category", "label": "Category", "default": "AFL" },
        { "type": "text", "id": "title", "label": "Resource title", "default": "AFL Competition Goal Post Specification Sheet" },
        { "type": "text", "id": "standard", "label": "Standard reference", "default": "AS 2316" },
        { "type": "text", "id": "file_size", "label": "File type / size", "default": "PDF · 1.2MB" },
        { "type": "url", "id": "file_url", "label": "Download file URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Resources / Downloads",
      "blocks": [
        { "type": "resource", "settings": { "category": "AFL", "title": "AFL Competition Goal Post Spec Sheet", "standard": "AS 2316", "file_size": "PDF · 0.8MB" } },
        { "type": "resource", "settings": { "category": "Soccer", "title": "Soccer Goal Technical Specification", "standard": "AS 4284", "file_size": "PDF · 1.1MB" } },
        { "type": "resource", "settings": { "category": "Flagpoles", "title": "Commercial Flagpole Engineering Certificate", "standard": "AS 1170", "file_size": "PDF · 0.5MB" } },
        { "type": "resource", "settings": { "resource_type": "cad", "category": "AFL", "title": "AFL Goal Post — CAD Drawing (DWG)", "file_size": "DWG · 2.3MB" } },
        { "type": "resource", "settings": { "category": "Installation Guides", "title": "Goal Post Installation Guide", "file_size": "PDF · 3.4MB" } },
        { "type": "resource", "settings": { "category": "Installation Guides", "title": "Coaches Box Assembly Manual", "file_size": "PDF · 1.8MB" } }
      ]
    }
  ]
}
{% endschema %}
