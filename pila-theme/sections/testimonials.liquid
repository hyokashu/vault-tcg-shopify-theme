<section class="section section--tint">
  <div class="container">
    <div class="section__header">
      <p class="eyebrow">{{ section.settings.eyebrow | default: 'What Our Clients Say' }}</p>
      <h2 class="section__title">{{ section.settings.heading | default: 'Trusted by Australia\'s Best' }}</h2>
    </div>
    <div class="testimonials__wrap">
      <div class="testimonials__track" id="testimonialTrack">
        {%- for block in section.blocks -%}
          <div class="testimonial-card" {{ block.shopify_attributes }}>
            <p class="testimonial-card__quote">"{{ block.settings.quote }}"</p>
            <div class="testimonial-card__author">
              <div class="testimonial-card__avatar" aria-hidden="true">
                {%- if block.settings.avatar != blank -%}
                  <img src="{{ block.settings.avatar | image_url: width: 88 }}" alt="{{ block.settings.name | escape }}" width="44" height="44" loading="lazy">
                {%- else -%}
                  {{ block.settings.name | split: ' ' | first | slice: 0 }}{{ block.settings.name | split: ' ' | last | slice: 0 }}
                {%- endif -%}
              </div>
              <div>
                <div class="testimonial-card__name">{{ block.settings.name }}</div>
                <div class="testimonial-card__role">{{ block.settings.role }}{%- if block.settings.venue != blank -%}, {{ block.settings.venue }}{%- endif -%}</div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 2 -%}
        <div class="testimonials__controls" aria-label="Testimonial navigation">
          <button class="slider-btn slider-btn--prev" aria-label="Previous testimonials">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5"/></svg>
          </button>
          <button class="slider-btn slider-btn--next" aria-label="Next testimonials">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "What Our Clients Say" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trusted by Australia's Best" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote text", "default": "PILA's AFL goal posts are second to none. The installation team was professional, the quality is exceptional, and they've stood up perfectly through multiple AFL seasons." },
        { "type": "text", "id": "name", "label": "Person name", "default": "David Morgan" },
        { "type": "text", "id": "role", "label": "Role / title", "default": "Facilities Manager" },
        { "type": "text", "id": "venue", "label": "Venue or organisation", "default": "Melbourne Football Club" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar photo (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial", "settings": { "name": "David Morgan", "role": "Facilities Manager", "venue": "Melbourne Football Club" } },
        { "type": "testimonial", "settings": { "name": "Sarah Chen", "role": "Club Secretary", "venue": "Western United FC" } },
        { "type": "testimonial", "settings": { "name": "Mark Sullivan", "role": "Director of Operations", "venue": "Cricket Australia" } },
        { "type": "testimonial", "settings": { "name": "Jane Williams", "role": "Sport Infrastructure", "venue": "City of Melbourne Council" } }
      ]
    }
  ]
}
{% endschema %}
