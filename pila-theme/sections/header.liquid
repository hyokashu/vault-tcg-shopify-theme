<header class="site-header" role="banner">
  <!-- Utility bar -->
  <div class="utility-bar">
    <div class="container utility-bar__inner">
      <div class="utility-bar__left">
        {%- if section.settings.show_au_badge -%}
          <span class="utility-bar__badge">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Australian Made &amp; Owned
          </span>
        {%- endif -%}
        {%- if settings.email_address != blank -%}
          <a href="mailto:{{ settings.email_address }}" class="utility-bar__badge" style="color:rgba(255,255,255,.55)">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
            {{ settings.email_address }}
          </a>
        {%- endif -%}
      </div>
      <div class="utility-bar__right">
        {%- if settings.phone_number != blank -%}
          <a href="tel:{{ settings.phone_number | replace: ' ', '' | replace: '-', '' }}" class="utility-bar__phone">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75A2.25 2.25 0 014.5 4.5h.75c.621 0 1.125.504 1.125 1.125v.75c0 .414-.189.808-.508 1.07l-1.5 1.232a11.956 11.956 0 005.885 5.885l1.232-1.5a1.125 1.125 0 011.07-.508h.75c.621 0 1.125.504 1.125 1.125V19.5a2.25 2.25 0 01-2.25 2.25C7.716 21.75 2.25 15.527 2.25 6.75z"/></svg>
            <strong>{{ settings.phone_number }}</strong>
            {%- if settings.phone_label != blank -%}
              <span class="utility-bar__talk">— {{ settings.phone_label }}</span>
            {%- endif -%}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="nav-main">
    <div class="container nav-main__inner">
      <!-- Logo -->
      <a href="/" class="site-logo" aria-label="{{ shop.name }} home">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="140" height="42" loading="eager">
        {%- else -%}
          <span class="site-logo__wordmark">PIL<span>A</span></span>
        {%- endif -%}
      </a>

      <!-- Desktop nav -->
      <nav class="nav-links" aria-label="Main navigation">
        {%- for link in linklists[section.settings.main_menu].links -%}
          {%- if link.links.size > 0 -%}
            <div class="nav-link">
              <button class="nav-link__btn" aria-expanded="false" aria-haspopup="true">
                {{ link.title }}
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
              </button>
              <div class="nav-dropdown" role="menu">
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="nav-dropdown__item" role="menuitem">{{ child.title }}</a>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <div class="nav-link">
              <a href="{{ link.url }}" class="nav-link__btn {%- if link.active or link.current %} active{%- endif %}">{{ link.title }}</a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      <!-- Desktop CTA -->
      <div class="nav-actions">
        {%- if section.settings.show_search -%}
          <a href="/search" aria-label="Search" style="color:var(--pila-muted);display:flex;padding:.5rem;transition:color 180ms" onmouseenter="this.style.color='var(--pila-charcoal)'" onmouseleave="this.style.color='var(--pila-muted)'">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0015.803 15.803z"/></svg>
          </a>
        {%- endif -%}
        <a href="{{ settings.quote_page | default: '/pages/contact' }}" class="btn btn--primary">
          Get a Quote
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>

      <!-- Hamburger -->
      <button class="hamburger" aria-label="Open navigation" aria-expanded="false" aria-controls="mobile-drawer">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "limit": 1,
  "settings": [
    { "type": "link_list", "id": "main_menu", "label": "Main menu", "default": "main-menu" },
    { "type": "checkbox", "id": "show_au_badge", "label": "Show 'Australian Made & Owned' badge", "default": true },
    { "type": "checkbox", "id": "show_search", "label": "Show search icon", "default": true }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
