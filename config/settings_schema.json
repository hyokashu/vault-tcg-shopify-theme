  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "bebas_neue_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "Base font size",
        "min": 14,
        "max": 20,
        "step": 1,
        "default": 16,
        "unit": "px"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "max_width",
        "label": "Max page width",
        "min": 1000,
        "max": 1600,
        "step": 50,
        "default": 1300,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Space between sections",
        "min": 20,
        "max": 100,
        "step": 5,
        "default": 60,
        "unit": "px"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_twitter",
        "label": "X / Twitter URL"
      },
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_discord",
        "label": "Discord invite URL"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_drawer_enabled",
