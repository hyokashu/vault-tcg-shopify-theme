      },
      {
        "type": "textarea",
        "id": "cart_note_placeholder",
        "label": "Cart note placeholder text",
        "default": "Special instructions (e.g., gift wrapping)"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32x32px .png recommended"
      }
