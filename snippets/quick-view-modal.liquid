{%- comment -%}
  Quick view modal. Content loaded via AJAX.
{%- endcomment -%}

<div class="quick-view" data-quick-view-modal aria-hidden="true" role="dialog" aria-label="Quick view">
  <div class="quick-view__overlay" data-quick-view-close></div>
  <div class="quick-view__container">
    <button class="quick-view__close" data-quick-view-close aria-label="Close quick view">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="quick-view__content" data-quick-view-content>
      <!-- Content loaded via JS -->
      <div class="quick-view__loading">
        <svg width="32" height="32" viewBox="0 0 24 24" class="spinner"><circle cx="12" cy="12" r="10" fill="none" stroke="var(--color-primary)" stroke-width="3" stroke-dasharray="30 60"/></svg>
      </div>
    </div>
  </div>
</div>
