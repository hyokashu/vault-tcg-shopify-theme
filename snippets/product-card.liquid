{%- comment -%}
  Renders a product card.
  Accepts:
    - product: {Object}
    - show_vendor: {Boolean}
    - show_quick_view: {Boolean}
    - game_badge: {String} e.g. "Pokémon"
    - game_color: {String} hex e.g. "#F5C400"
{%- endcomment -%}

{%- assign is_sale = false -%}
{%- if product.compare_at_price > product.price -%}{%- assign is_sale = true -%}{%- endif -%}
{%- assign is_new = false -%}
{%- if product.tags contains 'new' -%}{%- assign is_new = true -%}{%- endif -%}
{%- assign is_hot = false -%}
{%- if product.tags contains 'hot' or product.tags contains 'bestseller' -%}{%- assign is_hot = true -%}{%- endif -%}
{%- assign stock_low = false -%}
{%- if product.variants.first.inventory_quantity > 0 and product.variants.first.inventory_quantity <= 5 -%}
  {%- assign stock_low = true -%}
{%- endif -%}
{%- assign savings_pct = 0 -%}
{%- if is_sale -%}
  {%- assign savings_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
{%- endif -%}

<div class="product-card{% unless product.available %} product-card--sold-out{% endunless %}" data-product-card data-product-url="{{ product.url }}">

  <div class="product-card__image-wrap">
    <a href="{{ product.url }}" class="product-card__image-link" aria-label="{{ product.title | escape }}" tabindex="0">
      {%- if product.featured_image -%}
        <img
          class="product-card__image"
          src="{{ product.featured_image | image_url: width: 600 }}"
          srcset="{{ product.featured_image | image_url: width: 300 }} 300w, {{ product.featured_image | image_url: width: 600 }} 600w"
          sizes="(max-width: 640px) 50vw, 25vw"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="600"
          height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
          loading="lazy"
        >
        {%- if product.images.size > 1 -%}
          <img
            class="product-card__image product-card__image--hover"
            src="{{ product.images[1] | image_url: width: 600 }}"
            alt=""
            width="600"
            height="{{ 600 | divided_by: product.images[1].aspect_ratio | round }}"
            loading="lazy"
          >
        {%- endif -%}
      {%- else -%}
        <div class="product-card__img-placeholder">
          {% render 'placeholder-pack-art', color_from: "#7C3AED", color_to: "#06B6D4" %}
        </div>
      {%- endif -%}
    </a>

    <!-- Badges -->
    <div class="product-card__badges">
      {%- if is_sale -%}
        <span class="product-card__badge product-card__badge--sale">-{{ savings_pct }}%</span>
      {%- endif -%}
      {%- if is_hot -%}
        <span class="product-card__badge product-card__badge--hot">🔥 Hot</span>
      {%- elsif is_new -%}
        <span class="product-card__badge product-card__badge--new">New</span>
      {%- endif -%}
      {%- unless product.available -%}
        <span class="product-card__badge product-card__badge--sold-out">Sold Out</span>
      {%- endunless -%}
    </div>

    {%- if game_badge != blank -%}
      <span class="product-card__game-badge" style="background: {{ game_color | default: 'var(--color-primary)' }}; color: {{ game_color | default: '#fff' | color_brightness | round }}{% if game_color == '#F5C400' %}: #000{% else %}: #fff{% endif %}">
        {{ game_badge }}
      </span>
    {%- endif -%}

    <!-- Overlay actions -->
    <div class="product-card__overlay">
      {%- if show_quick_view -%}
        <button class="product-card__quick-view-btn" data-quick-view="{{ product.url }}" aria-label="Quick view {{ product.title }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          Quick View
        </button>
      {%- endif -%}
    </div>

    <!-- Quick add (always visible on mobile) -->
    {%- if product.available -%}
      <div class="product-card__quick-add">
        {%- if product.variants.size == 1 -%}
          <form method="post" action="/cart/add" data-add-to-cart-form>
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit" class="product-card__atc" data-add-to-cart aria-label="Add to cart">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              <span data-add-to-cart-text>Add to Cart</span>
            </button>
          </form>
        {%- else -%}
          <a href="{{ product.url }}" class="product-card__atc product-card__atc--select">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            Select Options
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="product-card__info">
    {%- if show_vendor and product.vendor != blank -%}
      <span class="product-card__vendor">{{ product.vendor }}</span>
    {%- endif -%}

    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    {%- if stock_low -%}
      <p class="product-card__stock-warning">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Only {{ product.variants.first.inventory_quantity }} left!
      </p>
    {%- endif -%}

    <div class="product-card__price-row">
      {%- if is_sale -%}
        <span class="product-card__price product-card__price--sale">{{ product.price | money }}</span>
        <span class="product-card__price product-card__price--compare">{{ product.compare_at_price | money }}</span>
        <span class="product-card__save">Save {{ product.compare_at_price | minus: product.price | money }}</span>
      {%- else -%}
        <span class="product-card__price">{{ product.price | money }}</span>
      {%- endif -%}
    </div>
  </div>
</div>
